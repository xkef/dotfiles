#!/usr/bin/env fish
# shellcheck disable=all
# dots — unified dotfiles management command.
# Dispatches to profile subcommands on PATH.
#
# Usage: dots <command> [args]

switch $argv[1]
    case doctor check
        dots-doctor
    case update up
        dots-update
    case versions ver
        dots-versions
    case keys
        dots-keys $argv[2..-1]
    case skills
        if not command -q dots-skills
            echo "dots skills: dots-skills is provided by the ai package; stow/install ai to enable skill refresh." >&2
            return 127
        end
        dots-skills $argv[2..-1]
    case theme
        if not command -q theme
            echo "dots theme: theme is provided by the theme package; stow/install theme to enable theme switching." >&2
            return 127
        end
        theme $argv[2..-1]
    case help -h --help ''
        echo "Usage: dots <command>"
        echo ""
        echo "Commands:"
        echo "  doctor    Check dotfiles health (binaries, symlinks, configs)"
        echo "  update    Pull, re-stow, update plugins and tools"
        echo "  versions  Show installed tool versions"
        echo "  keys      Show keybinding reference"
        echo "  skills    Refresh shared agent skills from upstream"
        echo "  theme     Switch terminal + editor theme"
        echo ""
    case '*'
        echo "Unknown command: $argv[1]"
        echo "Run 'dots help' for usage."
        return 1
end
