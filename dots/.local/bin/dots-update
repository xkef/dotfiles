#!/usr/bin/env fish
# shellcheck disable=all
# dots update — fetch latest changes, re-stow packages, update plugins and tools.

set -g DOTS_DIR (test -f $HOME/.config/dotfiles/dir && cat $HOME/.config/dotfiles/dir || echo $HOME/dotfiles)

function _log
    printf '  %s\n' $argv
end

function _run_quiet
    set -l ctx $argv[1]
    set -l out ($argv[2..-1] 2>&1)
    or begin
        _log "  ! $ctx failed"
        for line in $out[-10..-1]
            _log "    | $line"
        end
        return 1
    end
end

function _stow_packages
    set -l manifest $DOTS_DIR/stow-packages
    if not test -r $manifest
        echo "dots-update: missing package manifest: $manifest" >&2
        return 1
    end
    while read -l line
        set line (string replace -r '#.*$' '' -- $line | string trim)
        test -n "$line"; and echo $line
    end <$manifest
end

function _link_target_abs -a link target
    if string match -q '/*' -- $target
        echo $target
    else
        path normalize (path dirname $link)/$target
    end
end

function _remove_stale_dotfile_links
    set -l roots \
        $HOME/.config \
        $HOME/.local/bin \
        $HOME/.local/share \
        $HOME/.ssh \
        $HOME/.agents \
        $HOME/.claude \
        $HOME/.codex \
        $HOME/.pi \
        $HOME/.ideavimrc

    for root in $roots
        test -e $root -o -L $root; or continue
        set -l links
        if test -L $root
            set links $root
        else if test -d $root
            set links (find $root -type l 2>/dev/null)
        end

        for link in $links
            test -L $link; or continue
            set -l target (readlink $link)
            set -l abs (_link_target_abs $link $target)
            if string match -q "$DOTS_DIR/*" -- $abs
                if not test -e $abs
                    _log "Removing stale link: $link"
                    rm -f $link
                end
            else if test "$abs" = "$DOTS_DIR"
                if not test -e $abs
                    _log "Removing stale link: $link"
                    rm -f $link
                end
            end
        end
    end
end

# ── Update steps ──────────────────────────────────────

printf '\n  Updating dotfiles...\n\n'

if test -d $DOTS_DIR/.jj
    _log "Fetching latest changes..."
    _run_quiet "jj fetch" jj --config signing.behavior=drop git fetch --all-remotes -R $DOTS_DIR || true
else if test -d $DOTS_DIR/.git
    _log "Pulling latest changes..."
    _run_quiet "git pull" git -C $DOTS_DIR pull --rebase || true
end

_log "Removing stale dotfile symlinks..."
_remove_stale_dotfile_links

_log "Re-stowing packages..."
for name in (_stow_packages)
    _run_quiet "stow $name" stow --dir=$DOTS_DIR -t $HOME -R $name || true
end

if command -q mise
    _log "Updating mise tools..."
    _run_quiet "mise upgrade" mise upgrade || true
end

_log "Updating neovim plugins..."
_run_quiet "nvim sync" nvim --headless "+Lazy! sync" +qa || true

_log "Updating mason tools..."
_run_quiet "mason update" nvim --headless "+MasonToolsUpdateSync" +qa || true

# Keep lazy-lock.json deterministically sorted
set -l lazy_lock $DOTS_DIR/nvim/.config/lazyvim/lazy-lock.json
if test -f $lazy_lock && command -q jq
    _log "Formatting lazy-lock.json..."
    jq --sort-keys . $lazy_lock >$lazy_lock.tmp && mv $lazy_lock.tmp $lazy_lock
end

# Re-apply current theme to regenerate derived configs (delta)
if command -q theme
    _log "Regenerating theme..."
    set -l name
    if test -r $HOME/.config/ghostty/config
        set -l match (string match -r '^\s*theme\s*=\s*(.+)' <$HOME/.config/ghostty/config)
        test (count $match) -ge 2; and set name (string trim $match[2])
    end
    test -n "$name"; or set name "Catppuccin Mocha"
    theme $name >/dev/null 2>&1 || true
end

printf '\n  Done!\n\n'
