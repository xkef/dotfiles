{
  "$schema": "https://nono.dev/schemas/nono-profile.schema.json",
  "extends": "claude-code",
  "meta": {
    "name": "claude",
    "version": "1.1.1",
    "description": "Claude Code with mise, jj, maven, npm, cargo, and keychain access"
  },
  "filesystem": {
    "allow": [
      "$HOME/Library/Keychains",
      "$HOME/.m2",
      "$HOME/.npm",
      "$XDG_CACHE_HOME/mise",
      "$XDG_CONFIG_HOME/jj",
      "$XDG_DATA_HOME/cargo"
    ],
    "read": [
      "$XDG_DATA_HOME/mise",
      "$XDG_STATE_HOME/mise",
      "$XDG_CONFIG_HOME/gh"
    ],
    "bypass_protection": ["$HOME/Library/Keychains"]
  }
}
