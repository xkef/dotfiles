#!/usr/bin/env bash
# Render per-tool AGENTS files from a shared base + per-tool overlay.
# Idempotent. Safe to run repeatedly. Invoked from `make ai-render`.
set -euo pipefail

DOTS="${DOTS_DIR:-$(cd "$(dirname "$0")/../../.." && pwd)}"
SHARED="$DOTS/ai/.config/ai-shared"
BASE="$SHARED/AGENTS.base.md"
OVERLAYS="$SHARED/overlays"

GENERATED_NOTE="<!-- Generated by ai/.local/bin/ai-agents-render. Do not edit by hand.
     Edit ai/.config/ai-shared/AGENTS.base.md or overlays/<tool>.append.md instead. -->"

render() {
  local tool="$1" outfile="$2" sandbox_paths="$3"
  local overlay="$OVERLAYS/${tool}.append.md"
  {
    printf '%s\n\n' "$GENERATED_NOTE"
    sed "s|{{SANDBOX_PATHS}}|${sandbox_paths}|g" "$BASE"
    if [[ -f "$overlay" ]]; then
      printf '\n'
      cat "$overlay"
    fi
  } >"$outfile"
  printf '  rendered %s\n' "${outfile#$DOTS/}"
}

render claude \
  "$DOTS/ai/.claude/CLAUDE.md" \
  '`~/.claude/` and `~/.config/claude-code/`'

render codex \
  "$DOTS/ai/.codex/AGENTS.md" \
  '`~/.codex/`'

render opencode \
  "$DOTS/ai/.config/opencode/AGENTS.md" \
  '`~/.config/opencode/` and `~/.local/share/opencode/`'

render pi \
  "$DOTS/ai/.pi/agent/AGENTS.md" \
  '`~/.pi/agent/`'
