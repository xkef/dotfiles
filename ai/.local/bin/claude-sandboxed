#!/usr/bin/env bash
set -e

DOTFILES_DIR="${DOTFILES_DIR:-$(<"$HOME/.config/dotfiles/dir")}"

if command -v nono &>/dev/null; then
  exec nono run \
    --profile claude-code \
    --allow-cwd \
    --allow-launch-services \
    --read "$DOTFILES_DIR" \
    --allow "$HOME/.cache/mise" \
    --allow "$HOME/.npm" \
    --allow "$HOME/.config/jj" \
    --read "$HOME/.config/gh" \
    --allow "$HOME/.local/share/cargo" \
    -- claude "$@"
else
  printf '\033[33m⚠ No sandbox available (install nono)\033[0m\n' >&2
  read -r -p "Continue without sandbox? [y/N] " reply
  [[ "$reply" =~ ^[Yy]$ ]] || exit 1
  exec claude "$@"
fi
