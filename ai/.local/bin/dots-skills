#!/usr/bin/env fish
# shellcheck disable=all
# dots-skills — manage shared agent skills pulled from upstream packs.
#
# Single owner of the install sentinel and the upstream source list.
# Locally-tracked skills (symlinked from ~/dotfiles/ai/.agents/skills/)
# are unaffected.
#
# Usage:
#   dots-skills ensure [agent]    install once; no-op while the sentinel exists
#   dots-skills refresh [agent]   drop the sentinel and reinstall from upstream
#   dots-skills                   same as refresh

set -l sentinel "$HOME/.cache/dotfiles/skills.shared.v5.installed"

# Upstream skill packs: '<repo> <skill>' ('*' installs every skill).
set -l upstreams \
    'mattpocock/skills *' \
    'vercel-labs/skills find-skills' \
    '2ykwang/agent-skills html-visual' \
    'Cocoon-AI/architecture-diagram-generator architecture-diagram'

# The skills CLI installs into ~/.agents/skills via its claude-code target;
# pi reads the same tree directly.
set -l install_target claude-code

set -l verb $argv[1]
set -l agent (test -n "$argv[2]"; and echo $argv[2]; or echo agents)

switch "$verb"
    case ensure refresh
    case ''
        set verb refresh
    case '*'
        echo "usage: dots-skills [ensure|refresh] [agent]" >&2
        exit 2
end

if test "$verb" = refresh
    rm -f $sentinel
end

test -f $sentinel; and exit 0
command -q npx; or exit 0

printf '\033[33m(installing shared skills for %s...)\033[0m\n' $agent >&2
for entry in $upstreams
    set -l parts (string split ' ' -- $entry)
    npx --yes skills@latest add $parts[1] \
        --global --agent $install_target --skill $parts[2] -y
    or exit $status
end

mkdir -p (dirname $sentinel)
touch $sentinel
