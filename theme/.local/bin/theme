#!/usr/bin/env fish
# shellcheck disable=all
# theme — unified theme switcher for ghostty, neovim, tmux, and shell tools.
#
# Accepts Ghostty theme names that have a matching LazyVim colorscheme plugin.
# Palette colors are read from Ghostty's built-in theme files. The core parses
# the palette and pushes OSC colors to running terminals; per-app application
# lives in ~/.config/theme.d/*.fish adapter fragments, sourced in glob order.
#
# Adapter contract: fragments run with $THEME_NAME, $t_palette (16 colors),
# $t_bg, $t_fg, and $t_cursor set, and may call _blend_hex / _hex_rgb. Each
# stow package owns the fragment for its app (terminal: ghostty state file,
# vcs: delta include, theme: nvim reload, tmux: status refresh). Numeric
# prefixes order them: the ghostty fragment writes the current-theme state
# before the nvim fragment reloads readers of it.
#
# Usage: theme [name|auto|--list|--current]

set -g GHOSTTY_CONFIG (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/ghostty/config

# ── Ghostty theme parser ─────────────────────────────
# Parses a Ghostty theme file and sets t_palette, t_bg, t_fg, t_cursor.

function _ghostty_theme_dirs
    echo (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/ghostty/themes
    test -n "$GHOSTTY_RESOURCES_DIR" && echo $GHOSTTY_RESOURCES_DIR/themes
    echo /Applications/Ghostty.app/Contents/Resources/ghostty/themes
end

function _parse_ghostty_theme -a name
    set -l theme_file
    for dir in (_ghostty_theme_dirs)
        test -f "$dir/$name" && set theme_file "$dir/$name" && break
    end
    test -n "$theme_file" || return 1

    set -g t_palette (seq 16 | string replace -r '.+' 000000)
    while read -l line
        set -l m (string match -r '(\d+)=#([0-9a-fA-F]{6})' -- $line)
        if test (count $m) -ge 3; and string match -q 'palette*' -- $line
            set t_palette[(math $m[2] + 1)] (string lower $m[3])
        else
            set m (string match -r '^(\w[\w-]*)\s*=\s*#?([0-9a-fA-F]{6})' -- $line)
            test (count $m) -ge 3 || continue
            switch $m[2]
                case background
                    set -g t_bg (string lower $m[3])
                case foreground
                    set -g t_fg (string lower $m[3])
                case cursor-color
                    set -g t_cursor (string lower $m[3])
            end
        end
    end <$theme_file
    # The while loop's status leaks failed substitutions from the last
    # parsed line (fish 4.7); a non-matching trailing line must not make
    # the parse look like a missing theme.
    return 0
end

# ── Supported themes ──────────────────────────────────
# Only Ghostty themes with a matching nvim colorscheme plugin are offered.
# Update this when adding/removing nvim colorscheme plugins.

function _is_supported -a name
    switch $name
        case "Catppuccin *"
            return 0
        case TokyoNight "TokyoNight *"
            return 0
        case "Rose Pine" "Rose Pine *"
            return 0
        case "Kanagawa Wave" "Kanagawa Lotus" "Kanagawa Dragon"
            return 0
        case "Everforest *"
            return 0
        case '*'
            return 1
    end
end

# ── Helpers ───────────────────────────────────────────

# Current theme lives in the untracked Ghostty include fragment written by
# the theme.d ghostty adapter; the tracked config only carries the default.
function _current_theme
    for source in (path dirname $GHOSTTY_CONFIG)/theme $GHOSTTY_CONFIG
        test -f $source; or continue
        set -l m (string match -r '^\s*theme\s*=\s*(.+)' <$source)
        if test (count $m) -ge 2
            string trim $m[2]
            return
        end
    end
    echo "Catppuccin Mocha"
end

# Blend two hex colors: _blend_hex bg fg weight(0-100).
function _blend_hex -a bg_hex fg_hex weight
    set -l w (test -n "$weight" && echo $weight || echo 20)
    set -l r1 (math "0x"(string sub -l 2 $bg_hex))
    set -l g1 (math "0x"(string sub -s 3 -l 2 $bg_hex))
    set -l b1 (math "0x"(string sub -s 5 -l 2 $bg_hex))
    set -l r2 (math "0x"(string sub -l 2 $fg_hex))
    set -l g2 (math "0x"(string sub -s 3 -l 2 $fg_hex))
    set -l b2 (math "0x"(string sub -s 5 -l 2 $fg_hex))
    printf '%02x%02x%02x' \
        (math "round(($r1 * (100 - $w) + $r2 * $w) / 100)") \
        (math "round(($g1 * (100 - $w) + $g2 * $w) / 100)") \
        (math "round(($b1 * (100 - $w) + $b2 * $w) / 100)")
end

# ── Terminal colors ───────────────────────────────────
# Push palette changes to the terminal via OSC 4/10/11/12.
# Ghostty's config reload handles persistence for new windows, but OSC
# sequences are needed to update the running terminal (especially inside tmux).

function _hex_rgb -a hex
    echo (string sub -l 2 $hex)/(string sub -s 3 -l 2 $hex)/(string sub -s 5 -l 2 $hex)
end

function _apply_terminal_colors
    set -l seq ""
    for i in (seq 0 15)
        set seq $seq(printf '\033]4;%d;rgb:%s\033\\' $i (_hex_rgb $t_palette[(math $i + 1)]))
    end
    set seq $seq(printf '\033]10;rgb:%s\033\\' (_hex_rgb $t_fg))
    set seq $seq(printf '\033]11;rgb:%s\033\\' (_hex_rgb $t_bg))
    set seq $seq(printf '\033]12;rgb:%s\033\\' (_hex_rgb $t_cursor))

    if test -n "$TMUX"
        for tty in (tmux list-clients -F '#{client_tty}')
            printf '%s' $seq >$tty
        end
    else if test -t 0
        printf '%s' $seq >/dev/tty
    end
end

# ── Apply ─────────────────────────────────────────────

function _source_theme_fragments
    set -l dir (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/theme.d
    for fragment in $dir/*.fish
        source $fragment
    end
end

function _apply_theme -a name
    if not _is_supported $name
        echo "Unsupported theme: $name (no nvim colorscheme plugin)"
        echo "Run 'theme --list' to see available themes."
        return 1
    end
    if not _parse_ghostty_theme $name
        echo "Unknown Ghostty theme: $name"
        return 1
    end

    set -g THEME_NAME $name
    _apply_terminal_colors
    _source_theme_fragments

    echo "Switched to: $name"
end

# ── Auto mode ─────────────────────────────────────────
# Pick a light or dark default based on system appearance.

function _system_is_dark
    switch (uname)
        case Darwin
            # `defaults read -g AppleInterfaceStyle` prints "Dark" when dark
            # mode is active, and errors otherwise. Capture into a variable
            # so an empty result doesn't collapse the `test` arguments.
            set -l style (defaults read -g AppleInterfaceStyle 2>/dev/null)
            test "$style" = Dark
        case Linux
            set -l scheme (gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)
            string match -q "*dark*" -- $scheme
        case '*'
            return 1
    end
end

function _auto_theme
    # Defaults: Catppuccin Latte (light) / Catppuccin Mocha (dark). Override
    # via DOTS_THEME_LIGHT / DOTS_THEME_DARK in the environment.
    set -l light_default (set -q DOTS_THEME_LIGHT && echo $DOTS_THEME_LIGHT || echo "Catppuccin Latte")
    set -l dark_default (set -q DOTS_THEME_DARK && echo $DOTS_THEME_DARK || echo "Catppuccin Mocha")
    if _system_is_dark
        _apply_theme $dark_default
    else
        _apply_theme $light_default
    end
end

function _list_themes
    set -l current (_current_theme)
    for dir in (_ghostty_theme_dirs)
        test -d "$dir" || continue
        for f in $dir/*
            set -l name (path basename $f)
            _is_supported $name || continue
            if test "$name" = "$current"
                echo "* $name"
            else
                echo "  $name"
            end
        end
        return 0
    end
end

# ── Main ──────────────────────────────────────────────

switch "$argv[1]"
    case --list -l
        _list_themes
    case --current
        _current_theme
    case auto
        _auto_theme
    case --completions
        for dir in (_ghostty_theme_dirs)
            test -d "$dir" || continue
            for f in $dir/*
                set -l name (path basename $f)
                _is_supported $name && echo $name
            end
            return 0
        end
    case --help -h
        echo "Usage: theme [name|--list|auto]"
        echo ""
        echo "  theme              Show current theme"
        echo "  theme <name>       Switch to a supported Ghostty theme"
        echo "  theme auto         Match system light/dark appearance"
        echo "  theme --list       List available themes"
        echo "  theme --current    Print current theme name"
    case ''
        echo "Current: "(_current_theme)
    case '*'
        _apply_theme (string join " " $argv)
end
