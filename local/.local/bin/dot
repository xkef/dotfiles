#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$(<"$HOME/.config/dotfiles/dir" 2>/dev/null || echo "$HOME/dotfiles")}"

log() { printf '  %s\n' "$1"; }
has() { command -v "$1" &>/dev/null; }

usage() {
  cat <<'USAGE'

  dot — dotfiles management

  Usage: dot <command>

  Commands:
    install       Full install (packages + stow + tools)
    install-adopt Install, adopting existing files into the repo
    update        Pull, re-stow, update plugins and tools
    stow          Stow all packages into ~
    unstow        Remove all symlinks from ~
    restow        Re-stow (fixes stale symlinks)
    test          Run smoke tests
    fmt           Format all dotfiles
    lint          Lint shell scripts and neovim config
    edit          Open dotfiles in $EDITOR
    cd            Print dotfiles path (use: cd "$(dot cd)")
    macos         Apply macOS defaults (macOS only)

USAGE
}

cmd_install() { "$DOTFILES_DIR/install" "$@"; }
cmd_update()  { dotfiles-update; }
cmd_test()    { dotfiles-test; }

cmd_stow() {
  while IFS= read -r pkg; do
    [[ -z "$pkg" || ! -d "$DOTFILES_DIR/$pkg" ]] && continue
    stow --dir="$DOTFILES_DIR" -t "$HOME" "$pkg" || true
  done <"$DOTFILES_DIR/.stow-packages"
}

cmd_unstow() {
  while IFS= read -r pkg; do
    [[ -z "$pkg" || ! -d "$DOTFILES_DIR/$pkg" ]] && continue
    stow --dir="$DOTFILES_DIR" -t "$HOME" -D "$pkg" || true
  done <"$DOTFILES_DIR/.stow-packages"
}

cmd_restow() {
  while IFS= read -r pkg; do
    [[ -z "$pkg" || ! -d "$DOTFILES_DIR/$pkg" ]] && continue
    stow --dir="$DOTFILES_DIR" -t "$HOME" -R "$pkg" || true
  done <"$DOTFILES_DIR/.stow-packages"
}

cmd_fmt() { make -C "$DOTFILES_DIR" fmt; }
cmd_lint() { make -C "$DOTFILES_DIR" lint; }
cmd_edit() { "${EDITOR:-nvim}" "$DOTFILES_DIR"; }
cmd_cd() { printf '%s\n' "$DOTFILES_DIR"; }

cmd_macos() {
  if [[ "$(uname -s)" != Darwin ]]; then
    log "macos subcommand is only available on macOS"
    return 1
  fi
  local script="$DOTFILES_DIR/macos-defaults"
  if [[ ! -x "$script" ]]; then
    log "macos-defaults script not found"
    return 1
  fi
  "$script"
}

if (( $# == 0 )); then
  usage
  exit 0
fi

case "$1" in
  install)       shift; cmd_install "$@" ;;
  install-adopt) cmd_install --adopt ;;
  update)        cmd_update ;;
  stow)          cmd_stow ;;
  unstow)        cmd_unstow ;;
  restow)        cmd_restow ;;
  test)          cmd_test ;;
  fmt)           cmd_fmt ;;
  lint)          cmd_lint ;;
  edit)          cmd_edit ;;
  cd)            cmd_cd ;;
  macos)         cmd_macos ;;
  -h|--help|help) usage ;;
  *)
    printf '  Unknown command: %s\n' "$1"
    usage
    exit 1
    ;;
esac
