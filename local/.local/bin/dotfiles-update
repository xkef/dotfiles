#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$(<"$HOME/.config/dotfiles/dir")}"

log() { printf '  %s\n' "$1"; }

run_quiet() {
  local context=${1:-}
  shift
  local output
  if output=$("$@" 2>&1); then
    return 0
  fi
  local rc=$?
  log "  ! ${context} failed (exit $rc)"
  if [[ -n "$output" ]]; then
    while IFS= read -r line; do
      log "    | $line"
    done <<<"$(printf '%s\n' "$output" | tail -30)"
  fi
  return $rc
}

printf '\n  Updating dotfiles...\n\n'

if [[ -d "$DOTFILES_DIR/.git" ]]; then
  log "Pulling latest changes..."
  run_quiet "git pull" git -C "$DOTFILES_DIR" pull --rebase || true
fi

log "Re-stowing packages..."
find "$DOTFILES_DIR" -name .DS_Store -delete 2>/dev/null
if ! git -C "$DOTFILES_DIR" diff --quiet 2>/dev/null; then
  log "  ! Uncommitted changes — skipping stow (would overwrite work)"
  log "    Commit or stash, then re-run."
else
  for pkg in "$DOTFILES_DIR"/*/; do
    pkg="$(basename "$pkg")"
    run_quiet "stow $pkg" stow --dir="$DOTFILES_DIR" -t "$HOME" --adopt "$pkg" || true
    run_quiet "git restore $pkg" git -C "$DOTFILES_DIR" restore "$pkg/" || true
  done
fi

if command -v mise &>/dev/null; then
  log "Updating mise tools..."
  run_quiet "mise upgrade" mise upgrade || true
fi

log "Updating neovim plugins..."
run_quiet "nvim plugin sync" nvim --headless "+Lazy! sync" +qa || true

log "Formatting lazy-lock.json..."
lazy_lock="$DOTFILES_DIR/nvim/.config/nvim/lazy-lock.json"
if [[ -f "$lazy_lock" ]] && command -v jq &>/dev/null; then
  jq --sort-keys . "$lazy_lock" >"$lazy_lock.tmp" && mv "$lazy_lock.tmp" "$lazy_lock"
fi

if command -v theme &>/dev/null; then
  log "Regenerating theme..."
  theme "$(sed -n 's/^name=//p' "$HOME/.config/theme/current" 2>/dev/null || echo catppuccin-mocha)" >/dev/null 2>&1 || true
fi

printf '\n  Done!\n\n'
