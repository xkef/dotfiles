#!/usr/bin/env bash
# Unified theme switcher for ghostty, neovim, tmux, and shell tools.
# Usage: theme [name|--list|--toggle]
#
# Changes terminal colors immediately via OSC escape sequences (works in
# ghostty, kitty, iTerm2, etc.) and updates config files for persistence.

set -euo pipefail

THEME_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/theme"
GHOSTTY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/config"
CURRENT_FILE="$THEME_DIR/current"

# ── Theme definitions ────────────────────────────────────
# Each call sets: ghostty_theme, nvim_scheme, background, bat_theme, pair,
# palette[0-15], theme_bg, theme_fg, theme_cursor

theme_config() {
  case "$1" in
    catppuccin-mocha)
      ghostty_theme="Catppuccin Mocha"
      nvim_scheme="catppuccin-mocha"
      background="dark"
      bat_theme="Catppuccin Mocha"
      pair="catppuccin-latte"
      palette=(45475a f38ba8 a6e3a1 f9e2af 89b4fa cba6f7 94e2d5 bac2de
               585b70 f38ba8 a6e3a1 f9e2af 89b4fa cba6f7 94e2d5 a6adc8)
      theme_bg=1e1e2e theme_fg=cdd6f4 theme_cursor=f5e0dc
      ;;
    catppuccin-latte)
      ghostty_theme="Catppuccin Latte"
      nvim_scheme="catppuccin-latte"
      background="light"
      bat_theme="Catppuccin Latte"
      pair="catppuccin-mocha"
      palette=(5c5f77 d20f39 40a02b df8e1d 1e66f5 8839ef 179299 acb0be
               6c6f85 d20f39 40a02b df8e1d 1e66f5 8839ef 179299 bcc0cc)
      theme_bg=eff1f5 theme_fg=4c4f69 theme_cursor=dc8a78
      ;;
    tokyonight)
      ghostty_theme="TokyoNight"
      nvim_scheme="tokyonight-night"
      background="dark"
      bat_theme="tokyonight_night"
      pair="tokyonight-day"
      palette=(15161e f7768e 9ece6a e0af68 7aa2f7 bb9af7 7dcfff a9b1d6
               414868 f7768e 9ece6a e0af68 7aa2f7 bb9af7 7dcfff c0caf5)
      theme_bg=1a1b26 theme_fg=c0caf5 theme_cursor=c0caf5
      ;;
    tokyonight-day)
      ghostty_theme="TokyoNight Day"
      nvim_scheme="tokyonight-day"
      background="light"
      bat_theme="tokyonight_day"
      pair="tokyonight"
      palette=(e9e9ed f52a65 587539 8c6c3e 2e7de9 9854f1 007197 6172b0
               a1a6c5 f52a65 587539 8c6c3e 2e7de9 9854f1 007197 3760bf)
      theme_bg=e1e2e7 theme_fg=3760bf theme_cursor=3760bf
      ;;
    rose-pine)
      ghostty_theme="Rose Pine"
      nvim_scheme="rose-pine"
      background="dark"
      bat_theme="rose-pine"
      pair="rose-pine-dawn"
      palette=(26233a eb6f92 31748f f6c177 9ccfd8 c4a7e7 ebbcba e0def4
               6e6a86 eb6f92 31748f f6c177 9ccfd8 c4a7e7 ebbcba e0def4)
      theme_bg=191724 theme_fg=e0def4 theme_cursor=524f67
      ;;
    rose-pine-dawn)
      ghostty_theme="Rose Pine Dawn"
      nvim_scheme="rose-pine-dawn"
      background="light"
      bat_theme="rose-pine-dawn"
      pair="rose-pine"
      palette=(f2e9e1 b4637a 286983 ea9d34 56949f 907aa9 d7827e 575279
               9893a5 b4637a 286983 ea9d34 56949f 907aa9 d7827e 575279)
      theme_bg=faf4ed theme_fg=575279 theme_cursor=cecacd
      ;;
    gruvbox-dark)
      ghostty_theme="Gruvbox Dark"
      nvim_scheme="gruvbox"
      background="dark"
      bat_theme="gruvbox-dark"
      pair="gruvbox-light"
      palette=(282828 cc241d 98971a d79921 458588 b16286 689d6a a89984
               928374 fb4934 b8bb26 fabd2f 83a598 d3869b 8ec07c ebdbb2)
      theme_bg=282828 theme_fg=ebdbb2 theme_cursor=ebdbb2
      ;;
    gruvbox-light)
      ghostty_theme="Gruvbox Light"
      nvim_scheme="gruvbox"
      background="light"
      bat_theme="gruvbox-light"
      pair="gruvbox-dark"
      palette=(fbf1c7 cc241d 98971a d79921 458588 b16286 689d6a 7c6f64
               928374 9d0006 79740e b57614 076678 8f3f71 427b58 3c3836)
      theme_bg=fbf1c7 theme_fg=3c3836 theme_cursor=3c3836
      ;;
    nord)
      ghostty_theme="Nord"
      nvim_scheme="nord"
      background="dark"
      bat_theme="Nord"
      pair="nord-light"
      palette=(3b4252 bf616a a3be8c ebcb8b 81a1c1 b48ead 88c0d0 e5e9f0
               4c566a bf616a a3be8c ebcb8b 81a1c1 b48ead 8fbcbb eceff4)
      theme_bg=2e3440 theme_fg=d8dee9 theme_cursor=d8dee9
      ;;
    nord-light)
      ghostty_theme="Nord Light"
      nvim_scheme="nord"
      background="light"
      bat_theme="OneHalfLight"
      pair="nord"
      palette=(e5e9f0 bf616a a3be8c ebcb8b 81a1c1 b48ead 88c0d0 3b4252
               d8dee9 bf616a a3be8c ebcb8b 81a1c1 b48ead 8fbcbb 2e3440)
      theme_bg=eceff4 theme_fg=2e3440 theme_cursor=4c566a
      ;;
    *) return 1 ;;
  esac
}

THEMES=(
  catppuccin-mocha
  catppuccin-latte
  tokyonight
  tokyonight-day
  rose-pine
  rose-pine-dawn
  gruvbox-dark
  gruvbox-light
  nord
  nord-light
)

# ── Bat theme sources (non-builtin themes that need downloading) ──

bat_theme_url() {
  case "$1" in
    "Catppuccin Mocha") echo "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme" ;;
    "Catppuccin Latte") echo "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Latte.tmTheme" ;;
    "tokyonight_night") echo "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/sublime/tokyonight_night.tmTheme" ;;
    "tokyonight_day")   echo "https://raw.githubusercontent.com/folke/tokyonight.nvim/main/extras/sublime/tokyonight_day.tmTheme" ;;
    "rose-pine")        echo "https://raw.githubusercontent.com/rose-pine/tm-theme/main/dist/rose-pine.tmTheme" ;;
    "rose-pine-dawn")   echo "https://raw.githubusercontent.com/rose-pine/tm-theme/main/dist/rose-pine-dawn.tmTheme" ;;
  esac
}

# ── Helpers ──────────────────────────────────────────────

current_theme() {
  if [[ -f "$CURRENT_FILE" ]]; then
    sed -n 's/^name=//p' "$CURRENT_FILE"
  else
    echo "catppuccin-mocha"
  fi
}

list_themes() {
  local current
  current=$(current_theme)
  for t in "${THEMES[@]}"; do
    theme_config "$t" 2>/dev/null
    if [[ "$t" == "$current" ]]; then
      echo "* $t ($background)"
    else
      echo "  $t ($background)"
    fi
  done
}

# ── OSC escape sequences ────────────────────────────────
# Change terminal colors live — works in ghostty, kitty, iTerm2, etc.
# Inside tmux, writes directly to each client's terminal (bypasses
# the need for allow-passthrough).

_send_osc() {
  if [[ -n "${TMUX:-}" ]]; then
    local tty
    while IFS= read -r tty; do
      printf '%s' "$1" > "$tty"
    done < <(tmux list-clients -F '#{client_tty}')
  else
    printf '%s' "$1" >/dev/tty
  fi
}

_put_template() {
  _send_osc "$(printf '\033]4;%d;rgb:%s\033\\' "$@")"
}

_put_template_var() {
  _send_osc "$(printf '\033]%d;rgb:%s\033\\' "$@")"
}

_hex_rgb() { echo "${1:0:2}/${1:2:2}/${1:4:2}"; }

apply_terminal_colors() {
  [[ -t 0 ]] || return 0  # skip if not interactive

  local i
  for i in {0..15}; do
    _put_template "$i" "$(_hex_rgb "${palette[$i]}")"
  done
  _put_template_var 10 "$(_hex_rgb "$theme_fg")"
  _put_template_var 11 "$(_hex_rgb "$theme_bg")"
  _put_template_var 12 "$(_hex_rgb "$theme_cursor")"
}

write_current() {
  local name="$1" bg="$2" bat="$3" nvim="$4"
  mkdir -p "$THEME_DIR"
  cat > "$CURRENT_FILE" << EOF
name=$name
variant=$bg
nvim=$nvim
bat_theme=$bat
EOF
}

# ── Reloaders ────────────────────────────────────────────

update_ghostty() {
  local ghostty_theme="$1"
  [[ -f "$GHOSTTY_CONFIG" ]] || return 0
  local tmp
  tmp=$(mktemp)
  sed "s/^theme = .*/theme = $ghostty_theme/" "$GHOSTTY_CONFIG" > "$tmp"
  mv "$tmp" "$GHOSTTY_CONFIG"
}

reload_neovim() {
  local scheme="$1" bg="$2"
  local dir
  for dir in "${XDG_RUNTIME_DIR:-}" "${TMPDIR:-}" "/tmp"; do
    [[ -n "$dir" && -d "$dir" ]] || continue
    for sock in "$dir"/nvim.*.0; do
      [[ -S "$sock" ]] || continue
      nvim --server "$sock" --remote-send \
        "<Cmd>set background=$bg<CR><Cmd>colorscheme $scheme<CR>" 2>/dev/null || true
    done
  done
}

reload_tmux() {
  command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1 || return 0

  # Set variant-dependent styles directly via tmux commands.
  # Static styles live in tmux.conf; only dark/light-dependent ones are set here.
  local pill_fg="colour0" border_dim="colour8"
  if [[ "$background" == "light" ]]; then
    pill_fg="colour7"
    border_dim="colour7"
  fi

  tmux set -g pane-border-style "fg=$border_dim" 2>/dev/null || true
  tmux set -g mode-style "bg=colour4,fg=$pill_fg" 2>/dev/null || true
  tmux set -g copy-mode-match-style "bg=colour3,fg=$pill_fg" 2>/dev/null || true
  tmux set -g copy-mode-current-match-style "bg=colour6,fg=$pill_fg" 2>/dev/null || true

  # Force status bar redraw to pick up new terminal colors
  tmux refresh-client -S 2>/dev/null || true
}

# ── Bat theme management ─────────────────────────────────

ensure_bat_theme() {
  command -v bat &>/dev/null || return 0
  local url
  url=$(bat_theme_url "$bat_theme")
  [[ -n "$url" ]] || return 0
  local themes_dir="${XDG_CONFIG_HOME:-$HOME/.config}/bat/themes"
  local dest="$themes_dir/${bat_theme}.tmTheme"
  [[ -f "$dest" ]] && return 0
  mkdir -p "$themes_dir"
  curl -fsSL -o "$dest" "$url" 2>/dev/null || return 0
  bat cache --build &>/dev/null
}

# ── Apply ────────────────────────────────────────────────

apply_theme() {
  local name="$1"

  if ! theme_config "$name"; then
    echo "Unknown theme: $name"
    echo ""
    echo "Available themes:"
    list_themes
    return 1
  fi

  apply_terminal_colors
  ensure_bat_theme
  write_current "$name" "$background" "$bat_theme" "$nvim_scheme"
  update_ghostty "$ghostty_theme"

  reload_neovim "$nvim_scheme" "$background"
  reload_tmux

  echo "Switched to: $name ($background)"
}

# ── Main ─────────────────────────────────────────────────

case "${1:-}" in
  --list|-l)
    list_themes
    ;;
  --toggle|-t)
    current=$(current_theme)
    if theme_config "$current"; then
      if [[ -z "$pair" ]]; then
        echo "No alternate variant for $current"
      else
        apply_theme "$pair"
      fi
    fi
    ;;
  --completions)
    for t in "${THEMES[@]}"; do
      theme_config "$t" 2>/dev/null
      echo "$t:$background"
    done
    ;;
  --help|-h)
    echo "Usage: theme [name|--list|--toggle]"
    echo ""
    echo "  theme           Show current theme and list available"
    echo "  theme <name>    Switch to theme"
    echo "  theme --list    List available themes"
    echo "  theme --toggle  Toggle between dark/light variant"
    echo ""
    echo "Themes:"
    list_themes
    ;;
  "")
    echo "Current: $(current_theme)"
    echo ""
    list_themes
    ;;
  *)
    apply_theme "$1"
    ;;
esac
