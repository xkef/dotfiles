THEMES=(
  catppuccin-mocha
  catppuccin-macchiato
  catppuccin-frappe
  catppuccin-latte
  tokyonight
  tokyonight-day
  rose-pine
  rose-pine-dawn
  gruvbox-dark
  gruvbox-light
  nord
  nord-light
  onedark
  onelight
  kanagawa
  kanagawa-lotus
  everforest-dark
  everforest-light
  dracula
)

# ── Helpers ──────────────────────────────────────────────

current_theme() {
  if [[ -f "$CURRENT_FILE" ]]; then
    sed -n 's/^name=//p' "$CURRENT_FILE"
  else
    echo "catppuccin-mocha"
  fi
}

list_themes() {
  local current
  current=$(current_theme)
  for t in "${THEMES[@]}"; do
    theme_config "$t" 2>/dev/null
    if [[ "$t" == "$current" ]]; then
      echo "* $t ($background)"
    else
      echo "  $t ($background)"
    fi
  done
}

# ── OSC escape sequences ────────────────────────────────
# Change terminal colors live — works in ghostty, kitty, iTerm2, etc.
# Inside tmux, writes directly to each client's terminal (bypasses
# the need for allow-passthrough).

_send_osc() {
  if [[ -n "${TMUX:-}" ]]; then
    local tty
    while IFS= read -r tty; do
      printf '%s' "$1" >"$tty"
    done < <(tmux list-clients -F '#{client_tty}')
  else
    printf '%s' "$1" >/dev/tty
  fi
}

_hex_rgb() { echo "${1:0:2}/${1:2:2}/${1:4:2}"; }

apply_terminal_colors() {
  [[ -t 0 ]] || return 0 # skip if not interactive

  # Build all OSC sequences into a single string, then write once per
  # tty. This reduces 19 separate writes to 1 (significant in tmux
  # with multiple clients).
  local seq="" i
  for i in {0..15}; do
    seq+=$(printf '\033]4;%d;rgb:%s\033\\' "$i" "$(_hex_rgb "${palette[$i]}")")
  done
  seq+=$(printf '\033]10;rgb:%s\033\\' "$(_hex_rgb "$theme_fg")")
  seq+=$(printf '\033]11;rgb:%s\033\\' "$(_hex_rgb "$theme_bg")")
  seq+=$(printf '\033]12;rgb:%s\033\\' "$(_hex_rgb "$theme_cursor")")

  # Save for shell startup replay (new terminals apply this on init)
  printf '%s' "$seq" >"$THEME_DIR/osc-palette"

  _send_osc "$seq"
}

write_current() {
  local name="$1" bg="$2" bat="$3" nvim="$4"
  mkdir -p "$THEME_DIR"
  cat >"$CURRENT_FILE" <<EOF
name=$name
variant=$bg
nvim=$nvim
bat_theme=$bat
EOF

  local dark_or_light="true"
  [[ "$bg" == "light" ]] && dark_or_light="false"
  cat >"${XDG_CONFIG_HOME:-$HOME/.config}/git/delta.gitconfig" <<EOF
[delta]
	syntax-theme = $bat
	dark = $dark_or_light
EOF
}

# ── Reloaders ────────────────────────────────────────────

update_ghostty() {
  local ghostty_theme="$1"
  [[ -f "$GHOSTTY_CONFIG" ]] || return 0
  local tmp
  tmp=$(mktemp)
  sed "s/^theme = .*/theme = $ghostty_theme/" "$GHOSTTY_CONFIG" >"$tmp"
  mv "$tmp" "$GHOSTTY_CONFIG"
}

reload_neovim() {
  local scheme="$1" bg="$2"
  local dir
  for dir in "${XDG_RUNTIME_DIR:-}" "${TMPDIR:-}" "/tmp"; do
    [[ -n "$dir" && -d "$dir" ]] || continue
    for sock in "$dir"/nvim.*.0; do
      [[ -S "$sock" ]] || continue
      nvim --server "$sock" --remote-send \
        "<Cmd>set background=$bg<CR><Cmd>colorscheme $scheme<CR>" 2>/dev/null || true
    done
  done
}

reload_tmux() {
  command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1 || return 0

  # Only dark/light-dependent styles need updating here. Window formatting
  # is handled by catppuccin/tmux using ANSI colour references that
  # auto-adapt when the terminal palette changes via OSC.
  local pill_fg="colour0" border_dim="colour8"
  if [[ "$background" == "light" ]]; then
    pill_fg="colour7"
    border_dim="colour7"
  fi

  tmux set -g pane-border-style "fg=$border_dim" 2>/dev/null || true
  tmux set -g pane-active-border-style "fg=$border_dim" 2>/dev/null || true
  tmux set -g mode-style "bg=colour4,fg=$pill_fg" 2>/dev/null || true
  tmux set -g copy-mode-match-style "bg=colour3,fg=$pill_fg" 2>/dev/null || true
  tmux set -g copy-mode-current-match-style "bg=colour6,fg=$pill_fg" 2>/dev/null || true
  tmux set -g copy-mode-mark-style "bg=colour5,fg=$pill_fg" 2>/dev/null || true

  tmux refresh-client -S 2>/dev/null || true
}

# ── Apply ────────────────────────────────────────────────

apply_theme() {
  local name="$1"

  if ! theme_config "$name"; then
    echo "Unknown theme: $name"
    echo ""
    echo "Available themes:"
    list_themes
    return 1
  fi

  apply_terminal_colors
  write_current "$name" "$background" "$bat_theme" "$nvim_scheme"
  update_ghostty "$ghostty_theme"

  reload_neovim "$nvim_scheme" "$background"
  reload_tmux

  echo "Switched to: $name ($background)"
}

# ── Main ─────────────────────────────────────────────────

case "${1:-}" in
--list | -l)
  list_themes
  ;;
--toggle | -t)
  current=$(current_theme)
  if theme_config "$current"; then
    if [[ -z "$pair" ]]; then
      echo "No alternate variant for $current"
    else
      apply_theme "$pair"
    fi
  fi
  ;;
--completions)
  for t in "${THEMES[@]}"; do
    theme_config "$t" 2>/dev/null
    echo "$t:$background"
  done
  ;;
--help | -h)
  echo "Usage: theme [name|--list|--toggle]"
  echo ""
  echo "  theme           Show current theme and list available"
  echo "  theme <name>    Switch to theme"
  echo "  theme --list    List available themes"
  echo "  theme --toggle  Toggle between dark/light variant"
  echo ""
  echo "Themes:"
  list_themes
  ;;
"")
  echo "Current: $(current_theme)"
  echo ""
  list_themes
  ;;
*)
  apply_theme "$1"
  ;;
esac
