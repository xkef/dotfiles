#!/usr/bin/env fish
# shellcheck disable=all
# theme — unified theme switcher for ghostty, neovim, tmux, and shell tools.
#
# Reads theme definitions from ~/.local/share/theme/themes.conf and applies
# colors across all tools: terminal (via OSC), ghostty config, neovim remote,
# tmux styles, bat theme, and git-delta diff colors.
#
# Usage: theme [name|--list|--toggle]

set -g THEME_DIR (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/theme
set -g THEMES_CONF (set -q XDG_DATA_HOME && echo $XDG_DATA_HOME || echo $HOME/.local/share)/theme/themes.conf
set -g GHOSTTY_CONFIG (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/ghostty/config
set -g CURRENT_FILE $THEME_DIR/current

# ── Theme loader ──────────────────────────────────────
# Parses the INI-style themes.conf and populates t_* globals for the
# requested theme. Returns 1 if the theme name was not found.

function _load_theme -a name
    set -g t_ghostty ""
    set -g t_nvim ""
    set -g t_background ""
    set -g t_bat ""
    set -g t_pair ""
    set -g t_palette
    set -g t_bg ""
    set -g t_fg ""
    set -g t_cursor ""

    set -l in_section false
    while read -l line
        if test "$line" = "[$name]"
            set in_section true
            continue
        end
        if $in_section
            # Stop at the next section header
            if string match -qr '^\[' $line
                break
            end
            test -z "$line" && continue
            set -l kv (string split -m1 '=' $line)
            switch $kv[1]
                case ghostty
                    set -g t_ghostty $kv[2]
                case nvim
                    set -g t_nvim $kv[2]
                case background
                    set -g t_background $kv[2]
                case bat
                    set -g t_bat $kv[2]
                case pair
                    set -g t_pair $kv[2]
                case palette
                    set -g t_palette (string split ' ' $kv[2])
                case bg
                    set -g t_bg $kv[2]
                case fg
                    set -g t_fg $kv[2]
                case cursor
                    set -g t_cursor $kv[2]
            end
        end
    end <$THEMES_CONF

    test -n "$t_nvim"
end

# Extract all theme names from section headers in themes.conf.
function _list_theme_names
    string match -r '(?<=^\[)[a-z][-a-z0-9]*(?=\]$)' <$THEMES_CONF
end

# ── Helpers ───────────────────────────────────────────

function _current_theme
    if test -f $CURRENT_FILE
        string replace 'name=' '' (string match 'name=*' <$CURRENT_FILE)
    else
        echo catppuccin-mocha
    end
end

# Convert a 6-char hex color to the rr/gg/bb format used by OSC sequences.
function _hex_rgb -a hex
    echo (string sub -l 2 $hex)/(string sub -s 3 -l 2 $hex)/(string sub -s 5 -l 2 $hex)
end

# Blend two hex colors: _blend_hex bg fg weight(0-100).
# Used to generate translucent diff highlight backgrounds for git-delta.
function _blend_hex -a bg_hex fg_hex weight
    set -l w (test -n "$weight" && echo $weight || echo 20)
    set -l r1 (math "0x"(string sub -l 2 $bg_hex))
    set -l g1 (math "0x"(string sub -s 3 -l 2 $bg_hex))
    set -l b1 (math "0x"(string sub -s 5 -l 2 $bg_hex))
    set -l r2 (math "0x"(string sub -l 2 $fg_hex))
    set -l g2 (math "0x"(string sub -s 3 -l 2 $fg_hex))
    set -l b2 (math "0x"(string sub -s 5 -l 2 $fg_hex))
    printf '%02x%02x%02x' \
        (math "($r1 * (100 - $w) + $r2 * $w) / 100") \
        (math "($g1 * (100 - $w) + $g2 * $w) / 100") \
        (math "($b1 * (100 - $w) + $b2 * $w) / 100")
end

# ── OSC escape sequences ─────────────────────────────
# Change terminal colors live via OSC 4/10/11/12. Works in ghostty, kitty,
# iTerm2, etc. Inside tmux, writes directly to each client's tty.

function _send_osc -a seq
    if test -n "$TMUX"
        for tty in (tmux list-clients -F '#{client_tty}')
            printf '%s' $seq >$tty
        end
    else
        printf '%s' $seq >/dev/tty
    end
end

function _apply_terminal_colors
    test -t 0 || return 0

    # Build all OSC sequences into a single string to minimize writes
    set -l seq ""
    for i in (seq 0 15)
        set -l idx (math $i + 1)
        set seq $seq(printf '\033]4;%d;rgb:%s\033\\' $i (_hex_rgb $t_palette[$idx]))
    end
    set seq $seq(printf '\033]10;rgb:%s\033\\' (_hex_rgb $t_fg))
    set seq $seq(printf '\033]11;rgb:%s\033\\' (_hex_rgb $t_bg))
    set seq $seq(printf '\033]12;rgb:%s\033\\' (_hex_rgb $t_cursor))

    # Cache for replay on new shell sessions (see 06-theme.fish)
    mkdir -p $THEME_DIR
    printf '%s' $seq >$THEME_DIR/osc-palette

    _send_osc $seq
end

# ── Persistence ───────────────────────────────────────

# Write theme state and generate git-delta config with blended diff colors.
function _write_current -a name
    mkdir -p $THEME_DIR
    printf 'name=%s\nvariant=%s\nnvim=%s\nbat_theme=%s\n' \
        $name $t_background $t_nvim $t_bat >$CURRENT_FILE

    set -l dark_or_light true
    test $t_background = light && set dark_or_light false

    # Blend palette colors into the background for subtle diff highlights
    set -l red $t_palette[2]
    set -l green $t_palette[3]
    set -l dim $t_palette[9]
    set -l minus_bg (_blend_hex $t_bg $red 15)
    set -l minus_emph (_blend_hex $t_bg $red 30)
    set -l plus_bg (_blend_hex $t_bg $green 15)
    set -l plus_emph (_blend_hex $t_bg $green 30)

    set -l delta_conf (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/git/delta.gitconfig
    printf '[delta]
\tsyntax-theme = %s
\tdark = %s
\tminus-style = syntax "#%s"
\tminus-emph-style = syntax "#%s"
\tminus-empty-line-marker-style = syntax "#%s"
\tplus-style = syntax "#%s"
\tplus-emph-style = syntax "#%s"
\tplus-empty-line-marker-style = syntax "#%s"
\tline-numbers-minus-style = "#%s"
\tline-numbers-plus-style = "#%s"
\tline-numbers-zero-style = "#%s"
' $t_bat $dark_or_light $minus_bg $minus_emph $minus_bg $plus_bg $plus_emph $plus_bg $red $green $dim >$delta_conf
end

# ── Reloaders ─────────────────────────────────────────

function _update_ghostty
    test -f $GHOSTTY_CONFIG || return 0
    set -l tmp (mktemp)
    sed "s/^theme = .*/theme = $t_ghostty/" $GHOSTTY_CONFIG >$tmp
    mv $tmp $GHOSTTY_CONFIG
end

# Send colorscheme command to all running neovim instances via their sockets.
function _reload_neovim
    for dir in $XDG_RUNTIME_DIR $TMPDIR /tmp
        test -n "$dir" -a -d "$dir" || continue
        for sock in $dir/nvim.*.0
            test -S $sock || continue
            nvim --server $sock --remote-send \
                "<Cmd>set background=$t_background<CR><Cmd>colorscheme $t_nvim<CR>" 2>/dev/null || true
        end
    end
end

# Update tmux styles that depend on dark/light variant. Window formatting
# uses ANSI colour references that auto-adapt when the palette changes.
function _reload_tmux
    command -q tmux && tmux list-sessions &>/dev/null || return 0

    set -l pill_fg colour0
    set -l border_dim colour8
    if test $t_background = light
        set pill_fg colour7
        set border_dim colour7
    end

    tmux set -g pane-border-style "fg=$border_dim" 2>/dev/null || true
    tmux set -g pane-active-border-style "fg=$border_dim" 2>/dev/null || true
    tmux set -g mode-style "bg=colour4,fg=$pill_fg" 2>/dev/null || true
    tmux set -g copy-mode-match-style "bg=colour3,fg=$pill_fg" 2>/dev/null || true
    tmux set -g copy-mode-current-match-style "bg=colour6,fg=$pill_fg" 2>/dev/null || true
    tmux set -g copy-mode-mark-style "bg=colour5,fg=$pill_fg" 2>/dev/null || true
    tmux refresh-client -S 2>/dev/null || true
end

# ── Apply ─────────────────────────────────────────────

function _apply_theme -a name
    if not _load_theme $name
        echo "Unknown theme: $name"
        echo ""
        echo "Available themes:"
        _list_themes
        return 1
    end

    _apply_terminal_colors
    _write_current $name
    _update_ghostty
    _reload_neovim
    _reload_tmux

    echo "Switched to: $name ($t_background)"
end

function _list_themes
    set -l current (_current_theme)
    for t in (_list_theme_names)
        _load_theme $t
        if test $t = $current
            echo "* $t ($t_background)"
        else
            echo "  $t ($t_background)"
        end
    end
end

# ── Main ──────────────────────────────────────────────

switch "$argv[1]"
    case --list -l
        _list_themes
    case --toggle -t
        set -l current (_current_theme)
        if _load_theme $current
            if test -z "$t_pair"
                echo "No alternate variant for $current"
            else
                _apply_theme $t_pair
            end
        end
    case --completions
        for t in (_list_theme_names)
            _load_theme $t
            echo "$t:$t_background"
        end
    case --help -h
        echo "Usage: theme [name|--list|--toggle]"
        echo ""
        echo "  theme           Show current theme and list available"
        echo "  theme <name>    Switch to theme"
        echo "  theme --list    List available themes"
        echo "  theme --toggle  Toggle between dark/light variant"
        echo ""
        echo "Themes:"
        _list_themes
    case ''
        echo "Current: "(_current_theme)
        echo ""
        _list_themes
    case '*'
        _apply_theme $argv[1]
end
