#!/usr/bin/env fish
# shellcheck disable=all
# theme — unified theme switcher for ghostty, neovim, tmux, and shell tools.
#
# Accepts any Ghostty theme name. Palette colors are read from Ghostty's
# built-in theme files. bat and delta use terminal ANSI colors; nvim derives
# its colorscheme from the Ghostty theme name via convention.
#
# Usage: theme [name|--list]

set -g GHOSTTY_CONFIG (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/ghostty/config

# ── Ghostty theme parser ─────────────────────────────
# Parses a Ghostty theme file and sets t_palette, t_bg, t_fg, t_cursor.

function _ghostty_theme_dirs
    echo (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/ghostty/themes
    test -n "$GHOSTTY_RESOURCES_DIR" && echo $GHOSTTY_RESOURCES_DIR/themes
    echo /Applications/Ghostty.app/Contents/Resources/ghostty/themes
end

function _parse_ghostty_theme -a name
    set -l theme_file
    for dir in (_ghostty_theme_dirs)
        test -f "$dir/$name" && set theme_file "$dir/$name" && break
    end
    test -n "$theme_file" || return 1

    set -g t_palette (seq 16 | while read; echo 000000; end)
    while read -l line
        set -l m (string match -r '(\d+)=#([0-9a-fA-F]{6})' -- $line)
        if test (count $m) -ge 3; and string match -q 'palette*' -- $line
            set t_palette[(math $m[2] + 1)] (string lower $m[3])
        else
            set m (string match -r '^(\w[\w-]*)\s*=\s*#?([0-9a-fA-F]{6})' -- $line)
            test (count $m) -ge 3 || continue
            switch $m[2]
                case background
                    set -g t_bg (string lower $m[3])
                case foreground
                    set -g t_fg (string lower $m[3])
                case cursor-color
                    set -g t_cursor (string lower $m[3])
            end
        end
    end <$theme_file
end

# ── Supported themes ──────────────────────────────────
# Only Ghostty themes with a matching nvim colorscheme plugin are offered.
# Update this when adding/removing nvim colorscheme plugins.

function _is_supported -a name
    switch $name
        case "Catppuccin *"
            return 0
        case "TokyoNight" "TokyoNight *"
            return 0
        case "Rose Pine" "Rose Pine *"
            return 0
        case "Gruvbox Dark" "Gruvbox Dark Hard" "Gruvbox Light" "Gruvbox Light Hard"
            return 0
        case "Nord" "Nord Light"
            return 0
        case "Atom One Dark" "Atom One Light"
            return 0
        case "Kanagawa Wave" "Kanagawa Lotus" "Kanagawa Dragon"
            return 0
        case "Everforest *"
            return 0
        case "Dracula"
            return 0
        case '*'
            return 1
    end
end

# ── Helpers ───────────────────────────────────────────

function _current_theme
    if not test -f $GHOSTTY_CONFIG
        echo "Catppuccin Mocha"
        return
    end
    set -l m (string match -r '^\s*theme\s*=\s*(.+)' <$GHOSTTY_CONFIG)
    if test (count $m) -ge 2
        string trim $m[2]
    else
        echo "Catppuccin Mocha"
    end
end

# Blend two hex colors: _blend_hex bg fg weight(0-100).
function _blend_hex -a bg_hex fg_hex weight
    set -l w (test -n "$weight" && echo $weight || echo 20)
    set -l r1 (math "0x"(string sub -l 2 $bg_hex))
    set -l g1 (math "0x"(string sub -s 3 -l 2 $bg_hex))
    set -l b1 (math "0x"(string sub -s 5 -l 2 $bg_hex))
    set -l r2 (math "0x"(string sub -l 2 $fg_hex))
    set -l g2 (math "0x"(string sub -s 3 -l 2 $fg_hex))
    set -l b2 (math "0x"(string sub -s 5 -l 2 $fg_hex))
    printf '%02x%02x%02x' \
        (math "round(($r1 * (100 - $w) + $r2 * $w) / 100)") \
        (math "round(($g1 * (100 - $w) + $g2 * $w) / 100)") \
        (math "round(($b1 * (100 - $w) + $b2 * $w) / 100)")
end

# ── Delta config ──────────────────────────────────────

function _write_delta_config
    set -l red $t_palette[2]
    set -l green $t_palette[3]
    set -l dim $t_palette[9]
    set -l minus_bg (_blend_hex $t_bg $red 15)
    set -l minus_emph (_blend_hex $t_bg $red 30)
    set -l plus_bg (_blend_hex $t_bg $green 15)
    set -l plus_emph (_blend_hex $t_bg $green 30)

    set -l delta_conf (set -q XDG_CONFIG_HOME && echo $XDG_CONFIG_HOME || echo $HOME/.config)/git/delta.gitconfig
    printf '[delta]
\tsyntax-theme = ansi
\tminus-style = syntax "#%s"
\tminus-emph-style = syntax "#%s"
\tminus-empty-line-marker-style = syntax "#%s"
\tplus-style = syntax "#%s"
\tplus-emph-style = syntax "#%s"
\tplus-empty-line-marker-style = syntax "#%s"
\tline-numbers-minus-style = "#%s"
\tline-numbers-plus-style = "#%s"
\tline-numbers-zero-style = "#%s"
' $minus_bg $minus_emph $minus_bg $plus_bg $plus_emph $plus_bg $red $green $dim >$delta_conf
end

# ── Terminal colors ───────────────────────────────────
# Push palette changes to the terminal via OSC 4/10/11/12.
# Ghostty's config reload handles persistence for new windows, but OSC
# sequences are needed to update the running terminal (especially inside tmux).

function _hex_rgb -a hex
    echo (string sub -l 2 $hex)/(string sub -s 3 -l 2 $hex)/(string sub -s 5 -l 2 $hex)
end

function _apply_terminal_colors
    set -l seq ""
    for i in (seq 0 15)
        set seq $seq(printf '\033]4;%d;rgb:%s\033\\' $i (_hex_rgb $t_palette[(math $i + 1)]))
    end
    set seq $seq(printf '\033]10;rgb:%s\033\\' (_hex_rgb $t_fg))
    set seq $seq(printf '\033]11;rgb:%s\033\\' (_hex_rgb $t_bg))
    set seq $seq(printf '\033]12;rgb:%s\033\\' (_hex_rgb $t_cursor))

    if test -n "$TMUX"
        for tty in (tmux list-clients -F '#{client_tty}')
            printf '%s' $seq >$tty
        end
    else if test -t 0
        printf '%s' $seq >/dev/tty
    end
end

# ── Reloaders ─────────────────────────────────────────

function _update_ghostty
    test -f $GHOSTTY_CONFIG || return 0
    set -l tmp (mktemp)
    sed "s/^theme = .*/theme = $argv[1]/" $GHOSTTY_CONFIG >$tmp
    mv $tmp $GHOSTTY_CONFIG
end

function _reload_neovim
    for dir in $XDG_RUNTIME_DIR $TMPDIR /tmp
        test -n "$dir" -a -d "$dir" || continue
        for sock in $dir/nvim.*.0
            test -S $sock || continue
            nvim --server $sock --remote-send \
                "<Cmd>lua require('theme').apply()<CR>" 2>/dev/null || true
        end
    end
end

function _reload_tmux
    command -q tmux && tmux list-sessions &>/dev/null || return 0
    tmux refresh-client -S 2>/dev/null || true
end

# ── Apply ─────────────────────────────────────────────

function _apply_theme -a name
    if not _is_supported $name
        echo "Unsupported theme: $name (no nvim colorscheme plugin)"
        echo "Run 'theme --list' to see available themes."
        return 1
    end
    if not _parse_ghostty_theme $name
        echo "Unknown Ghostty theme: $name"
        return 1
    end

    _update_ghostty $name
    _apply_terminal_colors
    _write_delta_config
    _reload_neovim
    _reload_tmux

    echo "Switched to: $name"
end

function _list_themes
    set -l current (_current_theme)
    for dir in (_ghostty_theme_dirs)
        test -d "$dir" || continue
        for f in $dir/*
            set -l name (path basename $f)
            _is_supported $name || continue
            if test "$name" = "$current"
                echo "* $name"
            else
                echo "  $name"
            end
        end
        return 0
    end
end

# ── Main ──────────────────────────────────────────────

switch "$argv[1]"
    case --list -l
        _list_themes
    case --completions
        for dir in (_ghostty_theme_dirs)
            test -d "$dir" || continue
            for f in $dir/*
                set -l name (path basename $f)
                _is_supported $name && echo $name
            end
            return 0
        end
    case --help -h
        echo "Usage: theme [name|--list]"
        echo ""
        echo "  theme              Show current theme"
        echo "  theme <name>       Switch to any Ghostty theme"
        echo "  theme --list       List available themes"
    case ''
        echo "Current: "(_current_theme)
    case '*'
        _apply_theme (string join " " $argv)
end
