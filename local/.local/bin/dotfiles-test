#!/usr/bin/env bash
# Smoke test for dotfiles: validates configs parse correctly.
set -uo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$(<"$HOME/.config/dotfiles/dir" 2>/dev/null || echo "$HOME/dotfiles")}"

errors=0
check() {
  local desc=$1
  shift
  if "$@" &>/dev/null; then
    printf '  \033[32m✓\033[0m %s\n' "$desc"
  else
    printf '  \033[31m✗\033[0m %s\n' "$desc"
    ((errors++))
  fi
}

printf '\n  dotfiles smoke test\n\n'

# Shell
check "zsh syntax" zsh -n "$DOTFILES_DIR/zsh/.config/zsh/.zshrc"
for f in "$DOTFILES_DIR"/zsh/.config/zsh/conf.d/*.zsh; do
  check "zsh syntax: $(basename "$f")" zsh -n "$f"
done

# Neovim
if command -v nvim &>/dev/null; then
  check "nvim headless load" nvim --headless +"lua require('lazy')" +qa
fi

# Tmux
if command -v tmux &>/dev/null; then
  check "tmux config parse" timeout 10 tmux -L _smoke -f "$DOTFILES_DIR/tmux/.config/tmux/tmux.conf" start-server \; kill-server
fi

# Starship
if command -v starship &>/dev/null; then
  check "starship config" starship print-config
fi

# Markdown
if command -v markdownlint-cli2 &>/dev/null; then
  check "markdown lint" markdownlint-cli2
fi

# Git
check "git config" git config --list

printf '\n'
if ((errors)); then
  printf '  %d check(s) failed\n\n' "$errors"
  exit 1
else
  printf '  All checks passed\n\n'
fi
