#!/usr/bin/env fish
# shellcheck disable=all
# dots versions — show installed tool versions.

printf '\n'
for pair in \
    "fish:fish --version" \
    "starship:starship --version" \
    "atuin:atuin --version" \
    "fzf:fzf --version" \
    "television:tv --version" \
    "neovim:nvim --version" \
    "tmux:tmux -V" \
    "ghostty:ghostty --version" \
    "zed:zed --version" \
    "git:git --version" \
    "delta:delta --version" \
    "jj:jj version" \
    "yazi:yazi --version" \
    "mise:mise --version" \
    "claude:claude --version"
    set -l parts (string split ':' $pair)
    set -l name $parts[1]
    set -l cmd (string split ' ' $parts[2])
    if not command -q $cmd[1]
        printf '  \e[2m%-14s not installed\e[0m\n' $name
        continue
    end
    set -l v (eval $parts[2] 2>/dev/null | string match -r '[0-9]+\.[0-9][0-9a-z.]*')
    set v $v[-1]
    printf '  %-14s %s\n' $name (test -n "$v" && echo $v || echo "unknown")
end
printf '\n'
