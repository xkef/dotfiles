#!/bin/bash
# 37% ctx В· 45.2kв†‘ 3.1kв†“ В· Opus 4.6 В· 1m 23s В· $0.42 В· +87 -12 В· ~/dotfiles

input=$(cat)

eval "$(echo "$input" | jq -r '
  @sh "MODEL=\(.model.display_name)",
  @sh "PCT=\(.context_window.used_percentage // 0 | floor)",
  @sh "DURATION_MS=\(.cost.total_duration_ms // 0)",
  @sh "COST=\(.cost.total_cost_usd // 0)",
  @sh "IN_TOK=\(.context_window.total_input_tokens // 0)",
  @sh "OUT_TOK=\(.context_window.total_output_tokens // 0)",
  @sh "ADDED=\(.cost.total_lines_added // 0)",
  @sh "REMOVED=\(.cost.total_lines_removed // 0)",
  @sh "CWD=\(.cwd)"
')"

CYAN='\033[36m'
YELLOW='\033[33m'
RED='\033[31m'
GREEN='\033[32m'
DIM='\033[2m'
RESET='\033[0m'

if [ "$PCT" -ge 75 ]; then
  PCT_COLOR="$RED"
elif [ "$PCT" -ge 50 ]; then
  PCT_COLOR="$YELLOW"
else
  PCT_COLOR="$CYAN"
fi

DURATION_SEC=$((DURATION_MS / 1000))
MINS=$((DURATION_SEC / 60))
SECS=$((DURATION_SEC % 60))

if [ "$MINS" -gt 0 ]; then
  TIME="${MINS}m ${SECS}s"
else
  TIME="${SECS}s"
fi

COST_FMT=$(printf '$%.2f' "$COST")

fmt_tokens() {
  if [ "$1" -ge 1000 ]; then
    printf '%s.%sk' "$((($1) / 1000))" "$((($1 % 1000) / 100))"
  else
    printf '%s' "$1"
  fi
}

TOK="$(fmt_tokens "$IN_TOK")в†‘ $(fmt_tokens "$OUT_TOK")в†“"

LINES=""
if [ "$ADDED" -gt 0 ] || [ "$REMOVED" -gt 0 ]; then
  LINES=" ${DIM}В·${RESET} ${GREEN}+${ADDED}${RESET} ${RED}-${REMOVED}${RESET}"
fi

DIR="${CWD/#$HOME/~}"

printf '%b\n' "${PCT_COLOR}${PCT}%${RESET} ctx ${DIM}В·${RESET} ${TOK} ${DIM}В·${RESET} ${MODEL} ${DIM}В·${RESET} ${TIME} ${DIM}В·${RESET} ${COST_FMT}${LINES} ${DIM}В·${RESET} ${DIM}${DIR}${RESET}"
