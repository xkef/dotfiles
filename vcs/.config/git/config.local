# Machine-local git overrides (identity, signing, credential helpers).
# This file is included by ~/.config/git/config.
# On a new machine, edit this to match the local environment.

[credential "https://github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
  helper =
  helper = !/opt/homebrew/bin/gh auth git-credential
