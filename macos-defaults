#!/usr/bin/env bash
# macOS developer defaults — run once on fresh install or after major upgrade.
# Curated from mathiasbynens/dotfiles, wincent/wincent, and paulirish/dotfiles.
#
# Usage:
#   ./macos-defaults               Apply all settings (backs up previous values)
#   ./macos-defaults --dry-run     Show what would change without applying
#   ./macos-defaults --restore     Restore from most recent backup
#   ./macos-defaults --restore F   Restore from specific backup file F
set -euo pipefail

if [[ "$(uname -s)" != Darwin ]]; then
  echo "This script is macOS-only." >&2
  exit 1
fi

DRY_RUN=false
RESTORE=false
[[ "${1:-}" == "--dry-run" || "${1:-}" == "-n" ]] && DRY_RUN=true
[[ "${1:-}" == "--restore" ]] && RESTORE=true

BACKUP_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/macos-defaults"

log() { printf '  %s\n' "$1"; }

changed=0
skipped=0
missing=0

TMP_DOMAIN="com.dotfiles.macos-defaults-check"

# Read current value of a defaults entry. Prints "" if unset.
read_default() {
  local flag="" domain key
  if [[ "$1" == "-currentHost" ]]; then
    flag="-currentHost"
    domain="$2"
    key="$3"
  else
    domain="$1"
    key="$2"
  fi
  defaults $flag read "$domain" "$key" 2>/dev/null || true
}

# Normalize a value to the format `defaults read` returns,
# by round-tripping through a temp domain.
normalize() {
  local type="$1" value="$2"
  defaults write "$TMP_DOMAIN" __check "$type" "$value" 2>/dev/null
  defaults read "$TMP_DOMAIN" __check 2>/dev/null || echo "$value"
  defaults delete "$TMP_DOMAIN" __check &>/dev/null || true
}

# Apply or diff a single defaults entry.
# Usage: apply [-currentHost] domain key -type value
apply() {
  local flag="" domain key type value
  if [[ "$1" == "-currentHost" ]]; then
    flag="-currentHost"
    shift
  fi
  domain="$1"
  key="$2"
  type="$3"
  value="$4"

  if $DRY_RUN; then
    local current expected
    current=$(read_default $flag "$domain" "$key")
    expected=$(normalize "$type" "$value")

    # Normalize booleans
    if [[ "$type" == "-bool" ]]; then
      [[ "$current" == "1" || "$current" == "true" ]] && current="1" || current="0"
      [[ "$expected" == "1" || "$expected" == "true" ]] && expected="1" || expected="0"
    fi

    if [[ -z "$current" ]]; then
      printf '  \033[33m+\033[0m %s %s \033[2m(not set -> %s)\033[0m\n' "$domain" "$key" "$value"
      ((missing++)) || true
    elif [[ "$current" != "$expected" ]]; then
      printf '  \033[31m~\033[0m %s %s \033[2m(%s -> %s)\033[0m\n' "$domain" "$key" "$current" "$value"
      ((changed++)) || true
    else
      ((skipped++)) || true
    fi
  else
    local current
    current=$(read_default $flag "$domain" "$key")
    if [[ -n "$current" ]]; then
      printf '%s\t%s\t%s\t%s\t%s\n' "$flag" "$domain" "$key" "$type" "$current" >> "$BACKUP_FILE"
    fi
    defaults $flag write "$domain" "$key" "$type" "$value"
  fi
}

if $RESTORE; then
  backup="${2:-$(ls -t "$BACKUP_DIR"/*.tsv 2>/dev/null | head -1)}"
  if [[ -z "$backup" || ! -f "$backup" ]]; then
    echo "No backup found." >&2
    exit 1
  fi
  printf '\n  Restoring from %s\n\n' "$backup"
  while IFS=$'\t' read -r flag domain key type value; do
    log "$domain $key -> $value"
    defaults $flag write "$domain" "$key" "$type" "$value"
  done < "$backup"
  printf '\n  Restored. Some changes require a logout/restart.\n\n'
  exit 0
fi

if $DRY_RUN; then
  printf '\n  macOS defaults (dry run)\n\n'
else
  mkdir -p "$BACKUP_DIR"
  BACKUP_FILE="$BACKUP_DIR/$(date +%Y%m%d-%H%M%S).tsv"
  printf '\n  Applying macOS defaults...\n'
  log "Backup: $BACKUP_FILE"
  printf '\n'
  osascript -e 'tell application "System Preferences" to quit' 2>/dev/null || true
  sudo -v
  while true; do
    sudo -n true
    sleep 60
    kill -0 "$$" || exit
  done 2>/dev/null &
fi

# ── Typing & Input ────────────────────────────────────

$DRY_RUN || log "Typing & input..."
apply NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
apply NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
apply NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
apply NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
apply NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
apply NSGlobalDomain ApplePressAndHoldEnabled -bool false
apply NSGlobalDomain KeyRepeat -int 2
apply NSGlobalDomain InitialKeyRepeat -int 15
apply NSGlobalDomain AppleKeyboardUIMode -int 3

# ── Finder ────────────────────────────────────────────

$DRY_RUN || log "Finder..."
apply NSGlobalDomain AppleShowAllExtensions -bool true
apply com.apple.finder ShowPathbar -bool true
apply com.apple.finder ShowStatusBar -bool true
apply com.apple.finder _FXSortFoldersFirst -bool true
apply com.apple.finder FXDefaultSearchScope -string "SCcf"
apply com.apple.finder FXPreferredViewStyle -string "Nlsv"
apply com.apple.finder FXEnableExtensionChangeWarning -bool false
apply com.apple.finder DisableAllAnimations -bool true
apply com.apple.finder QuitMenuItem -bool true
apply com.apple.desktopservices DSDontWriteNetworkStores -bool true
apply com.apple.desktopservices DSDontWriteUSBStores -bool true

# ── Dock ──────────────────────────────────────────────

$DRY_RUN || log "Dock..."
apply com.apple.dock autohide -bool true
apply com.apple.dock autohide-delay -float 0
apply com.apple.dock autohide-time-modifier -float 0.2
apply com.apple.dock show-recents -bool false
apply com.apple.dock mru-spaces -bool false
apply com.apple.dock launchanim -bool false
apply com.apple.dock expose-animation-duration -float 0.1
apply com.apple.dock tilesize -int 36

# ── Dialogs & Windows ────────────────────────────────

$DRY_RUN || log "Dialogs & windows..."
apply NSGlobalDomain NSNavPanelExpandedStateForSaveMode -bool true
apply NSGlobalDomain NSNavPanelExpandedStateForSaveMode2 -bool true
apply NSGlobalDomain PMPrintingExpandedStateForPrint -bool true
apply NSGlobalDomain PMPrintingExpandedStateForPrint2 -bool true
apply NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false
apply NSGlobalDomain NSWindowResizeTime -float 0.001
apply com.apple.print.PrintingPrefs "Quit When Finished" -bool true

# ── Screen ────────────────────────────────────────────

$DRY_RUN || log "Screen..."
apply com.apple.screensaver askForPassword -int 1
apply com.apple.screensaver askForPasswordDelay -int 0
apply com.apple.screencapture disable-shadow -bool true
apply com.apple.screencapture type -string "png"

# ── Trackpad ──────────────────────────────────────────

$DRY_RUN || log "Trackpad..."
apply com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
apply -currentHost NSGlobalDomain com.apple.mouse.tapBehavior -int 1
apply NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# ── Sound ─────────────────────────────────────────────

$DRY_RUN || log "Sound..."
apply NSGlobalDomain com.apple.sound.beep.feedback -bool false
apply NSGlobalDomain com.apple.sound.uiaudio.enabled -int 0

# ── TextEdit ──────────────────────────────────────────

$DRY_RUN || log "TextEdit..."
apply com.apple.TextEdit RichText -int 0
apply com.apple.TextEdit PlainTextEncoding -int 4
apply com.apple.TextEdit PlainTextEncodingForWrite -int 4

# ── Activity Monitor ──────────────────────────────────

$DRY_RUN || log "Activity Monitor..."
apply com.apple.ActivityMonitor OpenMainWindow -bool true
apply com.apple.ActivityMonitor IconType -int 5
apply com.apple.ActivityMonitor ShowCategory -int 0
apply com.apple.ActivityMonitor SortColumn -string "CPUUsage"
apply com.apple.ActivityMonitor SortDirection -int 0

# ── Safari (dev) ──────────────────────────────────────

$DRY_RUN || log "Safari dev tools..."
apply com.apple.Safari IncludeDevelopMenu -bool true
apply com.apple.Safari WebKitDeveloperExtrasEnabledPreferenceKey -bool true
apply com.apple.Safari "com.apple.Safari.ContentPageGroupIdentifier.WebKit2DeveloperExtrasEnabled" -bool true
apply NSGlobalDomain WebKitDeveloperExtras -bool true

# ── Time Machine ─────────────────────────────────────

$DRY_RUN || log "Time Machine..."
apply com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true

# ── Software Update ──────────────────────────────────

$DRY_RUN || log "Software Update..."
apply com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true
apply com.apple.SoftwareUpdate ScheduleFrequency -int 1
apply com.apple.SoftwareUpdate AutomaticDownload -int 1
apply com.apple.SoftwareUpdate CriticalUpdateInstall -int 1

# ── Finish ────────────────────────────────────────────

defaults delete "$TMP_DOMAIN" &>/dev/null || true

if $DRY_RUN; then
  total=$((changed + missing + skipped))
  printf '\n  %d setting(s): %d to change, %d to add, %d already set\n\n' \
    "$total" "$changed" "$missing" "$skipped"
else
  log "Restarting affected apps..."
  for app in "Activity Monitor" "Dock" "Finder" "Safari" "SystemUIServer"; do
    killall "$app" &>/dev/null || true
  done
  printf '\n  Done. Some changes require a logout/restart.\n\n'
fi
