{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "lineWidth": 100,
  "markdown": {
    "emphasisKind": "asterisks",
    "strongKind": "asterisks",
    "textWrap": "maintain"
  },
  "includes": ["**/*.md"],
  "excludes": [
    "**/node_modules/**",
    ".claude-notes/**",
    "ai/.pi/agent/**",
    "ai/.claude/CLAUDE.md",
    "ai/.codex/AGENTS.md",
    "ai/.config/opencode/AGENTS.md"
  ],
  "plugins": ["https://plugins.dprint.dev/markdown-0.22.1.wasm"]
}
