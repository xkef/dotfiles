#!/usr/bin/env bash
# Dotfiles installer — auto-detects OS, installs packages, stows configs.
set -uo pipefail

DOTFILES="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$HOME/.config/dotfiles"
[[ -f "$HOME/.config/dotfiles/dir" ]] || printf '%s\n' "$DOTFILES" >"$HOME/.config/dotfiles/dir"

log() { printf '  %s\n' "$1"; }
has() { command -v "$1" &>/dev/null; }

run_quiet() {
  local context=${1:-}
  shift
  local output
  if output=$("$@" 2>&1); then
    return 0
  fi
  local rc=$?
  log "  ! ${context} failed (exit $rc)"
  if [[ -n "$output" ]]; then
    while IFS= read -r line; do
      log "    | $line"
    done <<< "$(printf '%s\n' "$output" | tail -30)"
  fi
  return $rc
}

# ── Install packages ──────────────────────────────────

printf '\n  dotfiles\n\n'

case "$(uname -s)" in
Darwin)
  if ! has brew; then
    log "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  log "brew bundle..."
  run_quiet "brew bundle" brew bundle --file="$DOTFILES/Brewfile"
  ;;
Linux)
  if [[ -f /etc/arch-release ]]; then
    sudo -v
    log "pacman..."
    # shellcheck disable=SC2046
    run_quiet "pacman install" sudo pacman -Sy --needed --noconfirm $(cat "$DOTFILES/pkgs.arch")
  elif [[ -f "$DOTFILES/install-bins.sh" ]]; then
    log "Running install-bins.sh..."
    bash "$DOTFILES/install-bins.sh"
  else
    log "  ! install-bins.sh not found, skipping binary installs"
  fi
  ;;
esac
log "Packages installed"

# ── Stow configs ──────────────────────────────────────

find "$DOTFILES" -name .DS_Store -delete 2>/dev/null

adopt=false
for arg in "$@"; do
  case "$arg" in
    --adopt) adopt=true ;;
  esac
done

if $adopt; then
  # --adopt + checkout overwrites uncommitted changes — abort if worktree is dirty.
  if [[ -d "$DOTFILES/.git" ]] && ! git -C "$DOTFILES" diff --quiet 2>/dev/null; then
    log "  ! Uncommitted changes detected — commit or stash before running install."
    log "    (--adopt would overwrite your in-progress work)"
    exit 1
  fi
fi

while IFS= read -r pkg; do
  [[ -z "$pkg" ]] && continue
  if [[ ! -d "$DOTFILES/$pkg" ]]; then
    log "  ! stow: package dir '$pkg' not found, skipping"
    continue
  fi
  if $adopt; then
    if run_quiet "stow $pkg" stow --dir="$DOTFILES" -t "$HOME" --adopt "$pkg"; then
      run_quiet "git restore $pkg" git -C "$DOTFILES" restore "$pkg/"
    else
      log "  ! stow $pkg: failed — resolve manually"
    fi
  else
    if ! run_quiet "stow $pkg" stow --dir="$DOTFILES" -t "$HOME" "$pkg"; then
      log "  ! stow $pkg: conflict — run with --adopt to resolve"
    fi
  fi
done <"$DOTFILES/.stow-packages"

# ── Default shell ─────────────────────────────────────

zsh="$(command -v zsh 2>/dev/null || true)"
if [[ -n "$zsh" && "$zsh" != "${SHELL:-}" ]]; then
  if [[ -f /etc/shells ]] && ! grep -qx "$zsh" /etc/shells; then
    echo "$zsh" | sudo tee -a /etc/shells >/dev/null
  fi
  sudo chsh -s "$zsh" "$(whoami)" || log "  ! Run manually: chsh -s $zsh"
fi

printf '\n  Done! Run `exec zsh` to reload.\n\n'
