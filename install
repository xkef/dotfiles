#!/usr/bin/env python3
"""Dotfiles installer — auto-detects OS, installs packages, stows configs."""

import getpass
import os
import shutil
import subprocess
import sys
from pathlib import Path
from subprocess import CompletedProcess

DOTFILES = Path(__file__).resolve().parent
HOME = Path.home()
STOW_PACKAGES = (DOTFILES / ".stow-packages").read_text().split()


def log(msg: str) -> None:
  """Print a status line."""
  print(f"  {msg}")


def run(cmd: str, quiet: bool = False, context: str = "") -> CompletedProcess[bytes] | CompletedProcess[str]:
  """Run a shell command. When quiet, output is captured and shown only on failure."""
  if not quiet:
    return subprocess.run(cmd, shell=True, check=True)
  result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
  if result.returncode != 0:
    label = context or cmd
    log(f"  ! {label} failed (exit {result.returncode})")
    output = (result.stdout + result.stderr).strip()
    if output:
      for line in output.splitlines()[-30:]:
        log(f"    | {line}")
    raise subprocess.CalledProcessError(
      result.returncode, cmd, result.stdout, result.stderr
    )
  return result


def has(cmd: str) -> bool:
  """Check if a command exists on PATH."""
  return shutil.which(cmd) is not None


def detect_os() -> str:
  """Detect the current OS. Returns 'macos', 'arch', or 'linux'."""
  if sys.platform == "darwin":
    return "macos"
  if Path("/etc/arch-release").exists():
    return "arch"
  return "linux"


def stow_configs() -> None:
  """Symlink config directories into $HOME via GNU Stow."""
  for pkg in STOW_PACKAGES:
    pkg_dir = DOTFILES / pkg
    if not pkg_dir.is_dir():
      log(f"  ! stow: package dir '{pkg}' not found, skipping")
      continue
    try:
      run(f"stow --dir={DOTFILES} -t {HOME} --adopt {pkg}", quiet=True, context=f"stow {pkg}")
      run(f"git -C {DOTFILES} checkout -- {pkg}/", quiet=True, context=f"git restore {pkg}")
    except subprocess.CalledProcessError:
      log(f"  ! stow {pkg}: failed — resolve manually")


def set_default_shell() -> None:
  """Set zsh as the user's login shell, reusing the cached sudo ticket."""
  zsh = shutil.which("zsh")
  if not zsh or os.environ.get("SHELL") == zsh:
    return

  shells = Path("/etc/shells")
  if shells.exists() and zsh not in shells.read_text():
    run(f'echo "{zsh}" | sudo tee -a /etc/shells >/dev/null')

  try:
    run(f"sudo chsh -s {zsh} {getpass.getuser()}")
  except subprocess.CalledProcessError:
    log(f"  ! Run manually: chsh -s {zsh}")


def main() -> None:
  """Entry point: install packages, stow configs, switch to zsh."""
  print("\n  dotfiles\n")

  os_type = detect_os()
  if os_type == "macos":
    if not has("brew"):
      log("Installing Homebrew...")
      run('/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"')
    log("brew bundle...")
    run(f"brew bundle --file={DOTFILES / 'Brewfile'}", quiet=True, context="brew bundle")
  elif os_type == "arch":
    run("sudo -v")
    pkgs = (DOTFILES / "pkgs.arch").read_text().split()
    log("pacman...")
    run(f"sudo pacman -Sy --needed --noconfirm {' '.join(pkgs)}", quiet=True, context="pacman install")
  else:
    script = DOTFILES / "install-bins.sh"
    if script.exists():
      log("Running install-bins.sh...")
      run(f"bash {script}")
    else:
      log(f"  ! {script} not found, skipping binary installs")
  log("Packages installed")

  stow_configs()
  set_default_shell()

  print("\n  Done! Run `exec zsh` to reload.\n")


if __name__ == "__main__":
  main()
