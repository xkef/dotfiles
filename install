#!/usr/bin/env bash
# Dotfiles installer — auto-detects OS, installs packages, stows configs.
set -uo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$HOME/.config/dotfiles"
[[ -f "$HOME/.config/dotfiles/dir" ]] || printf '%s\n' "$DOTFILES_DIR" >"$HOME/.config/dotfiles/dir"

log() { printf '  %s\n' "$1"; }
has() { command -v "$1" &>/dev/null; }

run_quiet() {
  local context=${1:-}
  shift
  local output
  local log_file
  local rc
  log_file="$(mktemp "${TMPDIR:-/tmp}/dotfiles-install.XXXXXX.log")"
  output=$("$@" 2>&1 | tee "$log_file")
  rc=$?
  if [[ $rc -eq 0 ]]; then
    rm -f "$log_file"
    return 0
  fi
  log "  ! ${context} failed (exit $rc)"
  if [[ -n "$output" ]]; then
    while IFS= read -r line; do
      log "    | $line"
    done <<<"$(printf '%s\n' "$output" | tail -30)"
  fi
  log "    | full log: $log_file"
  return $rc
}

read_pkg_file() {
  sed 's/#.*//; s/[[:space:]]*$//; /^[[:space:]]*$/d' "$1"
}

ensure_paru() {
  if has paru; then
    return 0
  fi

  local tmpdir
  tmpdir="$(mktemp -d)"
  run_quiet "install base-devel" sudo pacman -S --needed --noconfirm base-devel
  run_quiet "clone paru" git clone https://aur.archlinux.org/paru-bin.git "$tmpdir/paru-bin" || return $?
  (
    cd "$tmpdir/paru-bin" || exit 1
    makepkg -si --noconfirm
  )
  local rc=$?
  rm -rf "$tmpdir"
  return $rc
}

# ── Install packages ──────────────────────────────────

printf '\n  dotfiles\n\n'

case "$(uname -s)" in
Darwin)
  if ! has brew; then
    log "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  log "brew bundle..."
  run_quiet "brew bundle" brew bundle --file="$DOTFILES_DIR/Brewfile"
  ;;
Linux)
  if [[ -f /etc/arch-release ]]; then
    sudo -v
    run_quiet "refresh pacman databases" sudo pacman -Sy --noconfirm || exit $?
    mapfile -t packages < <(read_pkg_file "$DOTFILES_DIR/pkgs.arch")
    if ! systemd-detect-virt -q 2>/dev/null && [[ -f "$DOTFILES_DIR/pkgs.arch.gui" ]]; then
      mapfile -t gui_packages < <(read_pkg_file "$DOTFILES_DIR/pkgs.arch.gui")
      packages+=("${gui_packages[@]}")
    fi
    log "paru..."
    run_quiet "bootstrap paru" ensure_paru || exit $?
    paru_flags=(--needed --noconfirm)
    systemd-detect-virt -q 2>/dev/null && paru_flags+=(--mflags="-A")
    run_quiet "paru install" paru -S "${paru_flags[@]}" "${packages[@]}" || exit $?
  else
    log "Unsupported Linux distribution (only Arch is supported)."
    exit 1
  fi
  ;;
esac
log "Packages installed"

# ── Stow configs ──────────────────────────────────────

adopt=false
for arg in "$@"; do
  case "$arg" in
  --adopt) adopt=true ;;
  esac
done

if $adopt; then
  # --adopt + checkout overwrites uncommitted changes — abort if worktree is dirty.
  if [[ -d "$DOTFILES_DIR/.git" ]] && ! git -C "$DOTFILES_DIR" diff --quiet 2>/dev/null; then
    log "  ! Uncommitted changes detected — commit or stash before running install."
    log "    (--adopt would overwrite your in-progress work)"
    exit 1
  fi
fi

for pkg in "$DOTFILES_DIR"/*/; do
  pkg="$(basename "$pkg")"
  if $adopt; then
    if run_quiet "stow $pkg" stow --dir="$DOTFILES_DIR" -t "$HOME" --adopt "$pkg"; then
      run_quiet "git restore $pkg" git -C "$DOTFILES_DIR" restore "$pkg/"
    else
      log "  ! stow $pkg: failed — resolve manually"
    fi
  else
    if ! run_quiet "stow $pkg" stow --dir="$DOTFILES_DIR" -t "$HOME" "$pkg"; then
      log "  ! stow $pkg: conflict — run with --adopt to resolve"
    fi
  fi
done

# ── Install mise tools ────────────────────────────────

if has mise; then
  log "Installing mise tools..."
  mise trust 2>/dev/null
  mise install 2>&1 | sed 's/^mise ERROR/  ! mise:/' || true
fi

# ── Default shell ─────────────────────────────────────

fish="$(command -v fish 2>/dev/null || true)"
if [[ -n "$fish" && "$fish" != "${SHELL:-}" ]]; then
  if [[ -f /etc/shells ]] && ! grep -qxF "$fish" /etc/shells; then
    echo "$fish" | sudo tee -a /etc/shells >/dev/null
  fi
  sudo usermod -s "$fish" "$(whoami)" || log "  ! Run manually: chsh -s $fish"
fi

printf '\n  Done. Run exec fish to reload.\n\n'
