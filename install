#!/usr/bin/env bash
# Dotfiles installer — auto-detects OS, installs packages, stows configs.
set -uo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$HOME/.config/dotfiles"
[[ -f "$HOME/.config/dotfiles/dir" ]] || printf '%s\n' "$DOTFILES_DIR" >"$HOME/.config/dotfiles/dir"

log() { printf '  %s\n' "$1"; }
has() { command -v "$1" &>/dev/null; }

run_quiet() {
  local context=${1:-}
  shift
  local output
  if output=$("$@" 2>&1); then
    return 0
  fi
  local rc=$?
  log "  ! ${context} failed (exit $rc)"
  if [[ -n "$output" ]]; then
    while IFS= read -r line; do
      log "    | $line"
    done <<<"$(printf '%s\n' "$output" | tail -30)"
  fi
  return $rc
}

# ── Install packages ──────────────────────────────────

printf '\n  dotfiles\n\n'

case "$(uname -s)" in
Darwin)
  if ! has brew; then
    log "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  log "brew bundle..."
  run_quiet "brew bundle" brew bundle --file="$DOTFILES_DIR/Brewfile"
  ;;
Linux)
  if [[ -f /etc/arch-release ]]; then
    sudo -v
    log "pacman..."
    # shellcheck disable=SC2046
    run_quiet "pacman install" sudo pacman -S --needed --noconfirm \
      $(sed 's/#.*//; /^[[:space:]]*$/d' "$DOTFILES_DIR/pkgs.arch")
  else
    log "Unsupported Linux distribution (only Arch is supported)."
    exit 1
  fi
  ;;
esac
log "Packages installed"

# ── Stow configs ──────────────────────────────────────

adopt=false
for arg in "$@"; do
  case "$arg" in
  --adopt) adopt=true ;;
  esac
done

if $adopt; then
  # --adopt + checkout overwrites uncommitted changes — abort if worktree is dirty.
  if [[ -d "$DOTFILES_DIR/.git" ]] && ! git -C "$DOTFILES_DIR" diff --quiet 2>/dev/null; then
    log "  ! Uncommitted changes detected — commit or stash before running install."
    log "    (--adopt would overwrite your in-progress work)"
    exit 1
  fi
fi

for pkg in "$DOTFILES_DIR"/*/; do
  pkg="$(basename "$pkg")"
  if $adopt; then
    if run_quiet "stow $pkg" stow --dir="$DOTFILES_DIR" -t "$HOME" --adopt "$pkg"; then
      run_quiet "git restore $pkg" git -C "$DOTFILES_DIR" restore "$pkg/"
    else
      log "  ! stow $pkg: failed — resolve manually"
    fi
  else
    if ! run_quiet "stow $pkg" stow --dir="$DOTFILES_DIR" -t "$HOME" "$pkg"; then
      log "  ! stow $pkg: conflict — run with --adopt to resolve"
    fi
  fi
done

# ── Install mise tools ────────────────────────────────

if has mise; then
  log "Installing mise tools..."
  run_quiet "mise install" mise install
fi

# ── Default shell ─────────────────────────────────────

fish="$(command -v fish 2>/dev/null || true)"
if [[ -n "$fish" && "$fish" != "${SHELL:-}" ]]; then
  if [[ -f /etc/shells ]] && ! grep -qx "$fish" /etc/shells; then
    echo "$fish" | sudo tee -a /etc/shells >/dev/null
  fi
  sudo chsh -s "$fish" "$(whoami)" || log "  ! Run manually: chsh -s $fish"
fi

# ── Fish plugins ──────────────────────────────────────

if has fish; then
  log "Installing fish plugins..."
  fish -c 'fisher update 2>/dev/null' || log "  ! Fisher not yet installed — run: fish then it auto-installs"
fi

printf '\n  Done! Run `exec fish` to reload.\n\n'
