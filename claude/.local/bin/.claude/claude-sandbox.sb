(version 1)
(allow default)

;; Deny reading everything under home directory
(deny file-read* (subpath (param "HOME")))

;; Re-allow reading CWD and subdirectories
(allow file-read* (subpath (param "CWD")))

;; Re-allow claude config, auth, hooks, and local bin
(allow file-read* (subpath (param "CLAUDE_HOME")))
(allow file-read* (literal (param "CLAUDE_JSON")))
(allow file-read* (subpath (param "CLAUDE_AUTH")))
(allow file-read* (subpath (param "LOCAL_BIN")))
(allow file-read* (subpath (param "GIT_CONFIG")))

;; Allow executing scripts from local bin
(allow process-exec (subpath (param "LOCAL_BIN")))

;; Deny writing everything under home directory
(deny file-write* (subpath (param "HOME")))

;; Re-allow writing to CWD and claude config
(allow file-write* (subpath (param "CWD")))
(allow file-write* (subpath (param "CLAUDE_HOME")))
(allow file-write* (literal (param "CLAUDE_JSON")))
(allow file-write* (subpath (param "CLAUDE_AUTH")))
