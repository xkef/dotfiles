#!/usr/bin/env bash
set -e

DOTFILES_DIR="${DOTFILES_DIR:-$(<"$HOME/.config/dotfiles/dir")}"

if [[ "$(uname)" == "Darwin" ]]; then
  creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) &&
    printf '%s' "$creds" >"$HOME/.claude/.credentials.json"
  unset creds

  exec sandbox-exec \
    -D "CWD=$(pwd)" \
    -D "HOME=$HOME" \
    -D "CLAUDE_HOME=$HOME/.claude" \
    -D "CLAUDE_JSON=$HOME/.claude.json" \
    -D "CLAUDE_AUTH=$HOME/.config/claude-code" \
    -D "LOCAL_BIN=$HOME/.local/bin" \
    -D "GIT_CONFIG=$HOME/.config/git" \
    -D "DOTFILES=$DOTFILES_DIR" \
    -D "M2_REPO=$HOME/.m2" \
    -f "$HOME/.local/bin/.claude/claude-sandbox.sb" \
    claude "$@"
elif command -v bwrap &>/dev/null; then
  exec bwrap \
    --ro-bind / / \
    --dev /dev \
    --proc /proc \
    --tmpfs /tmp \
    --tmpfs "$HOME" \
    --bind "$(pwd)" "$(pwd)" \
    --bind "$HOME/.claude" "$HOME/.claude" \
    --bind "$HOME/.claude.json" "$HOME/.claude.json" \
    --bind "$HOME/.config/claude-code" "$HOME/.config/claude-code" \
    --bind "$HOME/.m2" "$HOME/.m2" \
    --ro-bind "$HOME/.local/bin" "$HOME/.local/bin" \
    --ro-bind "$HOME/.config/git" "$HOME/.config/git" \
    --ro-bind "$HOME/.config/dotfiles" "$HOME/.config/dotfiles" \
    --ro-bind "$DOTFILES_DIR" "$DOTFILES_DIR" \
    claude "$@"
else
  printf '\033[33m⚠ WARNING: No sandbox available (install sandbox-exec or bwrap)\033[0m\n' >&2
  read -r -p "Continue without sandbox? [y/N] " reply
  [[ "$reply" =~ ^[Yy]$ ]] || exit 1
  exec claude "$@"
fi
