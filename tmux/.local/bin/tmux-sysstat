#!/usr/bin/env bash
# CPU + memory for tmux status-right (optimized for minimal forks)
set -euo pipefail

readonly SMOOTH="${TMPDIR:-/tmp}/tmux-sysstat-smooth"
readonly OS=$(uname)

# ── CPU (normalized 0–100%, smoothed) ────────────────
if [[ "$OS" == Darwin ]]; then
  ncpu=$(sysctl -n hw.logicalcpu)
else
  ncpu=$(nproc)
fi
raw=$(ps -A -o %cpu= | awk -v c="$ncpu" '{s+=$1} END {printf "%.0f", s/c}')
((raw > 100)) && raw=100

prev=${raw}
[ -f "$SMOOTH" ] && prev=$(cat "$SMOOTH")
cpu=$(awk "BEGIN {printf \"%.0f\", 0.3 * $raw + 0.7 * $prev}")
echo "$cpu" >"$SMOOTH"

# ── Memory (used / total) ────────────────────────────
if [[ "$OS" == Darwin ]]; then
  read -r page_size total <<< "$(sysctl -n hw.pagesize hw.memsize)"
  used=$(vm_stat | awk -v ps="$page_size" '
    /Pages active/           { gsub(/[^0-9]/,"",$NF); a=$NF }
    /Pages wired/            { gsub(/[^0-9]/,"",$NF); w=$NF }
    /occupied by compressor/ { gsub(/[^0-9]/,"",$NF); c=$NF }
    END { printf "%.0f", (a + w + c) * ps }')
else
  read -r total used <<< "$(awk '
    /^MemTotal:/     { t=$2*1024 }
    /^MemAvailable:/ { a=$2*1024 }
    END { printf "%.0f %.0f", t, t-a }' /proc/meminfo)"
fi
mem_pct=$((used * 100 / total))
((mem_pct > 100)) && mem_pct=100

used_g=$(awk "BEGIN {printf \"%.1f\", $used / 1073741824}")
total_g=$(awk "BEGIN {printf \"%.0f\", $total / 1073741824}")

# ── Output ────────────────────────────────────────────
cc="colour8"
((cpu >= 80)) && cc="colour1"

printf '#[fg=%s]%3d%%  #[fg=colour8]%s/%sG' \
  "$cc" "$cpu" "$used_g" "$total_g"
