#!/usr/bin/env bash
# CPU + memory for tmux status-right
set -euo pipefail

readonly SMOOTH="${TMPDIR:-/tmp}/tmux-sysstat-smooth"

# ── CPU (normalized 0–100%, smoothed) ────────────────
raw=$(ps -A -o %cpu= | awk -v c="$(sysctl -n hw.logicalcpu)" '{s+=$1} END {printf "%.0f", s/c}')
((raw > 100)) && raw=100

prev=${raw}
[ -f "$SMOOTH" ] && prev=$(cat "$SMOOTH")
cpu=$(awk "BEGIN {printf \"%.0f\", 0.3 * $raw + 0.7 * $prev}")
echo "$cpu" >"$SMOOTH"

# ── Memory (used / total) ────────────────────────────
page_size=$(sysctl -n hw.pagesize)
total=$(sysctl -n hw.memsize)
eval "$(vm_stat | awk -F: '
  /Pages active/             { gsub(/[^0-9]/,"",$2); print "active="   $2 }
  /Pages wired/              { gsub(/[^0-9]/,"",$2); print "wired="    $2 }
  /occupied by compressor/   { gsub(/[^0-9]/,"",$2); print "compressed=" $2 }
')"
compressed=${compressed:-0}
used=$(((active + wired + compressed) * page_size))
mem_pct=$((used * 100 / total))
((mem_pct > 100)) && mem_pct=100

used_g=$(awk "BEGIN {printf \"%.1f\", $used / 1073741824}")
total_g=$(awk "BEGIN {printf \"%.0f\", $total / 1073741824}")

# ── Colors ────────────────────────────────────────────
cc="colour8"
((cpu >= 80)) && cc="colour1"

# ── Output ────────────────────────────────────────────
printf '#[fg=%s]%3d%%  #[fg=colour8]%s/%sG' \
  "$cc" "$cpu" "$used_g" "$total_g"
