#!/usr/bin/env bash
# Sesh session picker — uses fzf-tmux to create a native tmux popup.
# See: https://github.com/joshmedeski/sesh

session=$(sesh list --icons | fzf-tmux -p 95%,80% \
  --ansi --no-sort --reverse \
  --border-label ' sesh ' --prompt '> ' \
  --header 'C-a all | C-t tmux | C-g config | C-x zoxide | C-f find | C-w kill | C-/ preview' \
  --bind 'tab:down,btab:up' \
  --bind 'ctrl-a:change-prompt(> )+reload(sesh list --icons)' \
  --bind 'ctrl-t:change-prompt(tmux> )+reload(sesh list -t --icons)' \
  --bind 'ctrl-g:change-prompt(config> )+reload(sesh list -c --icons)' \
  --bind 'ctrl-x:change-prompt(zoxide> )+reload(sesh list -z --icons)' \
  --bind 'ctrl-f:change-prompt(find> )+reload(fd -H -d 2 -t d -E .Trash . ~)' \
  --bind 'ctrl-d:preview-half-page-down' \
  --bind 'ctrl-u:preview-half-page-up' \
  --bind 'ctrl-/:toggle-preview' \
  --bind 'ctrl-w:execute(tmux kill-session -t {2..})+change-prompt(> )+reload(sesh list --icons)' \
  --preview-window 'right:60%:nowrap' \
  --preview 'sesh preview {}') || exit 0

[[ -n "$session" ]] && sesh connect "$session"
